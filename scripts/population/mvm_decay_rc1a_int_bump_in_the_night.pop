    // Wave 1/5 ($1500)
    
    // 18 Mittens Heavies
    // 10 Heavyweight Champs
    
    // 1 Giant Demoman & 2 Steel Gauntlets

    // Support : Spies

    Wave
    {
        SpawnTemplate w1_bumper_car_intro

        StartWaveOutput
        {
            Target wave_start_relay
            Action Trigger
        }
        InitWaveOutput
        {
            Target wave_finished_relay_new_nobumpercar
            Action trigger
            Delay 0.1
        }
        DoneOutput
        {
            Target upgrade_notice
            Action Show
            Delay 1.5
        }

        WaveSpawn
        {
            Name "wave01"
            TotalCount 18
            MaxActive 5
            SpawnCount 1

            Where spawnbot

            WaitBetweenSpawns 1.5
            WaitBeforeStarting 10
            TotalCurrency 300
            TFBot
            {
                Class Heavyweapons
                Health 60
                Name "Fuzzball Champ"
                Skill Normal
                ClassIcon heavy_mittens
                WeaponRestrictions MeleeOnly
                Attributes AlwaysCrit
                  
                Item "The Holiday Punch"
                Item "Trapper's Flap"
            }
        }

        WaveSpawn
        {
            Name "wave01"
            TotalCount 10
            MaxActive 4
            SpawnCount 2

            Where spawnbot

            WaitBetweenSpawns 3
            WaitBeforeStarting 12
            TotalCurrency 350
            TFBot
            {
                Template T_TFBot_Heavyweapons_Heavyweight_Champ
                Action Mobber
            }
        }

        WaveSpawn
        {
            Name "support"
            TotalCount 16
            MaxActive 3
            SpawnCount 1

            Support 1

            Where spawnbot_short
            WaitForAllSpawned "wave01"
            WaitBetweenSpawns 5
            TFBot
            {
                Class Soldier
                ClassIcon soldier_pickaxe_escape
                Name "Escape Plan Soldier"
                WeaponRestrictions MeleeOnly
                Item "The Escape Plan"
                Item "The Data Mining Light"

                UseHumanAnimations 1
                
                Taunt
                {
                    Delay 0
                    Cooldown 1
                    IfLeftSpawn 1
                }
            }
        }

        WaveSpawn
        {
            Name "wave02"
            TotalCount 3
            MaxActive 3
            SpawnCount 3

            Where spawnbot

            WaitForAllSpawned "wave01"
            WaitBeforeStarting 10
            TotalCurrency 850
            Squad
            {
                TFBot
                {
                    Template T_TFBot_Giant_Demo_RapidFire
                    ClassIcon demo_spammer_package
                }
                TFBot
                {
                    Template T_TFBot_Heavyweapons_Fist
                }
                TFBot
                {
                    Template T_TFBot_Heavyweapons_Fist
                }
            }
        }
    }

