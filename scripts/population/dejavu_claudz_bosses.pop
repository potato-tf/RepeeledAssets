                    {
                        Target "!self"
                        Action "RunScriptCode"
                        Param "self.RemoveCond(Constants.ETFCond.TF_COND_MEDIGUN_UBER_BULLET_RESIST);self.RemoveCond(Constants.ETFCond.TF_COND_MEDIGUN_UBER_BLAST_RESIST);self.RemoveCond(Constants.ETFCond.TF_COND_MEDIGUN_UBER_FIRE_RESIST);"
                        Delay 0.5
                        IfHealthBelow 1500
                    }
                    FireInput
                    {
                        Target "!self"
                        Action "RunScriptCode"
                        Param "self.AddCond(Constants.ETFCond.TF_COND_MEDIGUN_UBER_BULLET_RESIST);self.AddCond(Constants.ETFCond.TF_COND_MEDIGUN_UBER_BLAST_RESIST);self.AddCond(Constants.ETFCond.TF_COND_MEDIGUN_UBER_FIRE_RESIST);"
                        Delay 3
                        IfHealthBelow 1500 
                    }	
                    FireInput
                    {
                        Target "!self"
                        Action "$BotCommand" 
                        Param "switch_action Spy"
                        Delay 1
                    }
                    FireInput
                    {
                        Target "!self"
                        Action "$BotCommand" 
                        Param "switch_action Mobber"
                        Delay 5
                    }
                }
            }
        }
