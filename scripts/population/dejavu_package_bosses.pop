						"deploy time decreased" 0.01
						"damage force reduction" 0.01
						"airblast vulnerability multiplier" 0.01
						"airblast vertical vulnerability multiplier" 0.1
						"airblast disabled" 1
						"health from healers reduced" 2
						"increased jump height" 2
						"cancel falling damage" 1
						"displace touched enemies" 1
					}
				}
				// phase 2
				LongRange_DeflectorHeavy [$SIGSEGV]
				{
					WeaponRestrictions PrimaryOnly
					Skill Expert
					CharacterAttributes
					{
						"move speed bonus"	0.4
						"health regen" 100
						"override footstep sound set" 2
						"deploy time decreased" 0.01
						"damage force reduction" 0.01
						"airblast vulnerability multiplier" 0.01
						"airblast vertical vulnerability multiplier" 0.1
						"health from healers reduced" 2
						"cancel falling damage" 1
					}
				}
				ShortRange_Soldier [$SIGSEGV]
				{
					WeaponRestrictions PrimaryOnly
					Skill Expert
					CharacterAttributes
					{
						"move speed bonus"	0.5
						"health regen" 40
						"override footstep sound set" 3
						"Projectile speed increased" 0.65
						"deploy time decreased" 0.01
						"damage force reduction" 0.01
						"airblast vulnerability multiplier" 0.01
						"airblast vertical vulnerability multiplier" 0.1
						"health from healers reduced" 2
						"increased jump height" 2
						"cancel falling damage" 1
						"damage bonus" 1.25
					}
				}
				// phase 3
				ConchSoldier [$SIGSEGV]
				{
					WeaponRestrictions PrimaryOnly
					Attributes HoldFireUntilFullReload
					Skill Expert
					Item "Demo Kabuto"
					Item "The Shogun's Shoulder Guard"
					Item "PY-40 Incinibot"
					Item "Alcoholic Automaton"
					Item "The Concheror"
					Attributes AlwaysCrit
					ItemAttributes
					{
						ItemName "The Concheror"
						"increase buff duration" 999
						"deploy time increased" 0.5
						"mult_dmgtaken_active" 0.1
					}
					CharacterAttributes
					{
						"move speed bonus"	0.5
						"override footstep sound set" 3
						"damage force reduction" 0.01
						"airblast vulnerability multiplier" 0.01
						"airblast vertical vulnerability multiplier" 0.1
						"health from healers reduced" 2
						"increased jump height" 1.5
						"cancel falling damage" 1
					}

					WeaponSwitch
					{
						Type "Primary"
						Delay 3
						Repeats 1
						Cooldown 0
