                "angles" "0 0 0"
                "disablebonefollowers" "1"
                "disableshadows" "1"
                "$module" "aimfollow"
                "$rotationfollow" "1"
            }
            point_tesla
            {
                "targetname" "boss_sparky"
                "parentname" "boss_thing"
                "beamcount_max" "12"
                "beamcount_min" "1"
                "interval_max" "0.2"
                "interval_min" "0.1"
                "lifetime_max" "1"
                "lifetime_min" "0.1"
                "m_color" "0 139 255"
                "m_flRadius" "1500"
                "origin" "0 0 50"
                "thick_max" "15"
                "thick_min" "5"
                "m_SoundName" "DoSpark"
                "texture" "sprites/physbeam.vmt"
            }
            info_particle_system
            {
                "targetname" "super_release"
                "effect_name" "powerup_supernova_explode_blue"
                "start_active" "0"
                "origin" "0 0 0.3"
            }
            logic_relay
            {
                "targetname" "boss_spawns"
                "OnTrigger" "player,$PlaySoundToSelf,=75/mvm/giant_heavy/giant_heavy_entrance.wav,0,-1"
                "OnTrigger" "upper_text2,Display,,0.4,-1"
                "OnTrigger" "lower_text1,Display,,1.8,-1"
            }
            logic_relay
            {
                "targetname" "firebomb_attack_relay"
                "OnTrigger" "!activator,$AddPlayerAttribute,increased jump height|0,0,-1"
                "OnTrigger" "!activator,$AddPlayerAttribute,no_jump|1,0,-1"
                "OnTrigger" "!activator,$AddPlayerAttribute,no_attack|1,0,-1"
                "OnTrigger" "!activator,$AddPlayerAttribute,move speed bonus|0.01,0,-1"
                "OnTrigger" "tf_gamerules,PlayVO,vo/mvm/norm/Engineer_mvm_specialcompleted01.mp3,0.1,-1"
                "OnTrigger" "!activator,$PlaySequence,taunt09,0.1,-1"
                "OnTrigger" "firebomb_launcher,FireOnce,,3.4,-1"
                "OnTrigger" "!activator,$PlaySequence,run_melee,4.7,-1"
                "OnTrigger" "!activator,$AddPlayerAttribute,increased jump height|1,4.7,-1"
                "OnTrigger" "!activator,$AddPlayerAttribute,no_jump|0,4.7,-1"
                "OnTrigger" "!activator,$AddPlayerAttribute,no_attack|0,4.7,-1"
                "OnTrigger" "!activator,$AddPlayerAttribute,move speed bonus|0.7,4.7,-1"
            }
            logic_relay
            {
                "targetname" "lightning_attack_relay"
                "OnTrigger" "RotatorSpawners,ForceSpawnAtEntityOrigin,boss_thing,0,-1"
                "OnTrigger" "!activator,$AddPlayerAttribute,increased jump height|0,0,-1"
                "OnTrigger" "!activator,$AddPlayerAttribute,no_jump|1,0,-1"
                "OnTrigger" "!activator,$AddPlayerAttribute,no_attack|1,0,-1"
                "OnTrigger" "!activator,$AddPlayerAttribute,move speed bonus|0.01,0,-1"
                "OnTrigger" "boss_sparky,TurnOn,,0,-1"
