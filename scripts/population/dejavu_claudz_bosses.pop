        prop_ufo
        { //548 -4567 1659
            OnSpawnOutput
            {
                Target "ufo_rotator"
                Action "ClearParent"
                Param  ""
                Delay  0.2
            }
            OnSpawnOutput
            {
                Target "ufo_rotator"
                Action "runscriptcode"
                Param  "
                    self.ValidateScriptScope()
                    local scope = self.GetScriptScope()
                    scope.thinkfunc <- function(){self.SetAbsOrigin(self.GetOrigin()+Vector(0,0,-1)); return -1}
                    scope.thinkfuncup <- function(){self.SetAbsOrigin(self.GetOrigin()+Vector(0,0,1)); return -1}

                    AddThinkToEnt(self,`thinkfunc`)
                "
                Delay  0.2
            }
            OnSpawnOutput
            {
                Target "ufo_rotator"
                Action "runscriptcode"
                Param  "AddThinkToEnt(self,`thinkfuncup`)"
                Delay  3.5
            }
            OnSpawnOutput
            {
                Target "ufo_prop_light"
                Action "disable"
                Param  ""
                Delay  5
            }
            func_rotating
            {
                "targetname" "ufo_rotator"
                //"parentname" ""
                "maxspeed" "10"
                "origin" "0 0 800"
                "spawnflags" "65"
                "mins" "-0.1 -0.1 -0.1"
                "maxs" "0.1 0.1 0.1"
                "dmg" "0"
                "fanfriction" "100"
                "volume" "7"
            }
            prop_dynamic
            {
                "parentname" "ufo_rotator"
                "targetname" "ufo_prop"
                "model" "models/props_invasion/props_alien/saucer.mdl"
                "health" "99999"
                "damagefilter" "filter_red"
                "gravity" "0.0"
                "angles" "0 0 0"
                "origin" "0 0 800"
                "modelscale" "1.0"
                "disableshadows" "1"
                "minhealthdmg" "1"
                "solid" "0"
                //"teamnum" "3"
                //"disablebonefollowers" "1"
                "renderamt" "0"
                "rendermode" "1"
            }
            point_spotlight
            {
                "parentname" "ufo_prop"
                "targetname" "ufo_prop_light"
                //"renderfx" "1" //slow wide pulse
                "renderamt" "0"
                "rendercolor" "50 255 190"
                "rendermode" "1" //additive 5
                "spotlightlength" "2000"
                "spotlightwidth" "300"
                "HDRColorScale" "1.0"
                "origin" "0 0 750"
                "angles" "90 0 0"
                "mindxlevel" "90"
                "spawnflags" "3"
            }
            OnSpawnOutput
            {
                "target" "ufo_prop"
                "action" "$SetKey$renderfx"
                "param" "7"
                "delay" "0.15"
            }
            OnSpawnOutput
            {
                "target" "ufo_prop"
                "action" "$SetKey$renderfx"
                "param" "5"
                "delay" "4"
            }
            OnSpawnOutput
            {
                Target "ufo_rotator"
                Action "kill"
                Param  ""
                Delay  10
            }
            OnSpawnOutput
            {
                Target "!activator"
                Action "RunScriptCode"
                Param  "
                    self.AddCondEx(64,4.0,self)
                    self.SetGravity(0.3)
                    EntFireByHandle(self, `DisableDamageForces`, null, 0.0, null, null)
                    EntFireByHandle(self, `EnableDamageForces`, null, 5, null, null)
                "
                Delay  0.1
            }
            OnSpawnOutput
            {
                Target "!activator"
                Action "RunScriptCode"
                Param  "
                    self.SetAbsOrigin(self.GetOrigin()+Vector(0,0,650))
                    self.AddCondEx(Constants.ETFCond.TF_COND_TELEPORTED, 0.5, self)
                "
                Delay  4
            }
            OnSpawnOutput
            {
                Target "!activator"
                Action "RunScriptCode"
                Param  "
                    self.SetGravity(1)
                "
                Delay  6
            }

        }

