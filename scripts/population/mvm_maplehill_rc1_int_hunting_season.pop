    PrecacheGeneric "materials/hud/leaderboard_class_pyro_bird2"
    PrecacheGeneric "materials/hud/leaderboard_class_pyro_bird2_giant"
    PrecacheGeneric "materials/hud/leaderboard_class_scout_birb"
