WaveSchedule
{
    PointTemplates
    {
        //// MAIN BOSSES ////

        //// MASTER MECHANIC POINTTEMPLATES ////
        MasterMechanicCoreLogic
        {
            // Main Boss Phases
            logic_relay // Attack Initialiser
            {
                "targetname" "MasterMechanic_AttackInit"

                "OnTrigger" "MasterMechanic_Phase1AttackPoolRelay,Trigger,,0,-1"
                "OnTrigger" "MasterMechanic_Phase2AttackPoolRelay,Trigger,,0,-1"
                "OnTrigger" "MasterMechanic_Phase3AttackPoolRelay,Trigger,,0,-1"
            }

            logic_relay // Phase 1 Relay
            {
                "targetname" "MasterMechanic_Phase1AttackPoolRelay"
                "spawnflags" "2"

                "OnTrigger" "MasterMechanic_Phase1AttackPool,PickRandomShuffle,,0,-1"
            }
            logic_relay // Phase 2 Relay
            {
                "targetname" "MasterMechanic_Phase2AttackPoolRelay"
                "spawnflags" "2"
                "startdisabled" "1"

                "OnTrigger" "MasterMechanic_Phase2AttackPool,PickRandomShuffle,,0,-1"
            }
            logic_relay // Phase 3 Relay
            {
                "targetname" "MasterMechanic_Phase3AttackPoolRelay"
                "spawnflags" "2"
                "startdisabled" "1"

                "OnTrigger" "MasterMechanic_Phase3AttackPool,PickRandomShuffle,,0,-1"
            }

            logic_case // Phase 1 Attack Pool
            {
                "targetname" "MasterMechanic_Phase1AttackPool"
                "OnCase01" "pop_interface,ChangeBotAttributes,MasterMechanic_RescueRangerShotgun,0,-1"
                "OnCase02" "pop_interface,ChangeBotAttributes,MasterMechanic_Capper,0,-1"
            }

            logic_case // Phase 2 Attack Pool
            {
                "targetname" "MasterMechanic_Phase2AttackPool"
                "OnCase01" "pop_interface,ChangeBotAttributes,MasterMechanic_Pomson,0,-1"
                "OnCase02" "pop_interface,ChangeBotAttributes,MasterMechanic_RescueRangerShotgun,0,-1"
                "OnCase03" "pop_interface,ChangeBotAttributes,MasterMechanic_ShortCircuit,0,-1"
            }

            logic_case // Phase 3 Attack Pool
            {
                "targetname" "MasterMechanic_Phase3AttackPool"
                "OnCase01" "pop_interface,ChangeBotAttributes,MasterMechanic_Pomson,0,-1"
                "OnCase02" "pop_interface,ChangeBotAttributes,MasterMechanic_ShortCircuit,0,-1"
                "OnCase03" "pop_interface,ChangeBotAttributes,MasterMechanic_NuclearShotgun,0,-1"
            }

            // Tank Phases
            logic_relay // Rocket Tank
            {
                "targetname" "MasterMechanic_RocketTankPhase"
                "OnTrigger" "pop_interface,$ResumeWaveSpawn,Wave9_Boss-RocketTank,0,-1"
                "OnTrigger" "pop_interface,ChangeBotAttributes,MasterMechanic_TankPowered,0,-1"
                "OnTrigger" "tf_gamerules,PlayVO,mvm/mvm_tele_deliver.wav,0,-1"
                "OnTrigger" "MasterMechanic_TankSummonFade,Fade,,0,-1"
                "OnTrigger" "!activator,$TeleportToEntity,tank_rodeo_target,0.55,-1"
            }

            logic_relay // Minigun Tank
            {
                "targetname" "MasterMechanic_MinigunTankPhase"
                "OnTrigger" "pop_interface,$ResumeWaveSpawn,Wave9_Boss-MinigunTank,0,-1"
                "OnTrigger" "pop_interface,ChangeBotAttributes,MasterMechanic_TankPowered,0,-1"
                "OnTrigger" "tf_gamerules,PlayVO,mvm/mvm_tele_deliver.wav,0,-1"
                "OnTrigger" "MasterMechanic_TankSummonFade,Fade,,0,-1"
                "OnTrigger" "!activator,$TeleportToEntity,tank_rodeo_target,0.55,-1"
            }

            logic_relay // Railgun Tank
            {
                "targetname" "MasterMechanic_RailgunTankPhase"
                "OnTrigger" "pop_interface,$ResumeWaveSpawn,Wave9_Boss-RailgunTank,0,-1"
                "OnTrigger" "pop_interface,ChangeBotAttributes,MasterMechanic_TankPowered,0,-1"
                "OnTrigger" "tf_gamerules,PlayVO,mvm/mvm_tele_deliver.wav,0,-1"
                "OnTrigger" "MasterMechanic_TankSummonFade,Fade,,0,-1"
                "OnTrigger" "!activator,$TeleportToEntity,tank_rodeo_target,0.55,-1"
            }
        }
        MasterMechanicCoreEffects
        {
            OnSpawnOutput
            {
                Target "MasterMechanic_Shield"
                Action "SetAttached"
                Param !self
            }
            prop_dynamic_ornament
            {
                "targetname" "MasterMechanic_Shield"
                "model" "models/effects/resist_shield/resist_shield.mdl"
                "modelscale" "1.5"
                "skin" "1"
                "solid" "0"

                "startdisabled" "1"
            }
        }
        MasterMechanicArenaEffects
        {
            point_clientcommand
            {
                "targetname" "clientcommand"
            }
            info_target
            {
                "targetname" "tank_rodeo_target"
                "origin" "-6143 -5249 -512"
            }
            env_fade
            {
                "targetname" "MasterMechanic_TankSummonFade"
                "rendercolor" "0 128 255"
                "renderamt" "192"
                "duration" "0.5"
                "spawnflags" "1"
            }
        }

