                "OnCase07" "StraightBeamAttack,ForceSpawnAtEntityOrigin,rotator_spawner7,0,-1"
                "OnCase08" "StraightBeamAttack,ForceSpawnAtEntityOrigin,rotator_spawner,0,-1"
            }
            logic_case
            {
