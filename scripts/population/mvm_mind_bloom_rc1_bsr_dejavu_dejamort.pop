	Wave // Main Boss - The Three Trolldiers
    {
        InitWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`wave_init_arena_electricmine_relay`, `Trigger`)
                    Convars.SetValue(`sig_mvm_beggar_stun_nerf`, 1)
                    EntFire(`BossRushPlayerSpawn`, `Disable`)
                    EntFire(`howmanyofthemleft`,`SetText`,`3?`, 0.5)

                    if (MusicSystemMent.MasterEntity == null || !MusicSystemMent.MasterEntity.IsValid())
					{
						MusicSystemMent.ResetAll();
						MusicSystemMent.HookByName(`bignet`);
					}
					MusicSystemMent.SetMusicTrack(`#mentrillum/mvm/music/bossrush/apocalyptic_reboot.wav`, 2.0, 2.0, 0.75);
                  "
        }
        StartWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`wave_start_relay`, `Trigger`)
                    EntFire(`BossRushPlayerSpawn`, `Enable`)
                  "
        }
        DoneOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`wave_finished_relay`, `Trigger`)
                    EntFire(`boss_rush_spawn_teleport_relay`, `Trigger`, null, 5)
                  "
        }
        
		CustomWaveNumber 15
		CustomMaxWaveNumber 0
        RedTeamWipeCausesWaveLoss 1

		SpawnTemplate MainBoss_TripleTrolldierArena

        WaveSpawn
        {
            Name "teleporthotfix"
            WaitBeforeStarting 5.1

            FirstSpawnOutput
            {
                Target BigNet
                Action RunScriptCode
                Param "
                        EntFire(`arena_teleport_relay`, `Trigger`)
                        MusicSystemMent.SetMusicTrack(``, 2.0, 2.0);
						EntFire(`tf_gamerules`, `PlayVO`, `boss_incoming.wav`, 2.4)
                      "
            }
        }

		WaveSpawn
		{
			Name "Wave17_TrolldierTrioSetup"
			WaitBeforeStarting 5

			FirstSpawnOutput
			{
				Target BigNet
				Action RunScriptCode
				Param "
						EntFire(`arena_electricmine_boss_spawn_relay`, `Disable`)
					  "
			}
		}
		WaveSpawn
		{
			Name "Wave17_TrolldierTrioSetup2"
			WaitBeforeStarting 7.5

			FirstSpawnOutput
			{
				Target BigNet
				Action RunScriptCode
				Param "
						EntFire(`bossrushspecialspawnlocation`, `ForceSpawnAtEntityOrigin`, `spawnbot_target_electricmine1`)
						EntFire(`bossrushspecialspawnlocation`, `ForceSpawnAtEntityOrigin`, `spawnbot_target_electricmine2`)
						EntFire(`bossrushspecialspawnlocation`, `ForceSpawnAtEntityOrigin`, `spawnbot_target_electricmine3`)
					  "
			}
		}

		WaveSpawn // Boss - Barry
		{
			Name "Wave17_Boss-Barry"
			Where spawnbot_boss
			TotalCount 1
			MaxActive 1
			SpawnCount 1
			WaitBeforeStarting 12.5
			WaitBetweenSpawns 0
			TotalCurrency 100

			TFBot
			{
				Template MainBoss_Barry
				FireInput
                {
                    Target !self
                    Action $TeleportToEntity
                    Param spawnbot_target_electricmine3
                    Delay 0.1
                    Repeats 1
                    Cooldown -1
                }
			}
			DoneOutput
            {
                Target BigNet
                Action RunScriptCode
                Param "
                        EntFire(`TrolldierGigaShockwaveInit`, `Disable`)
                        EntFire(`TrolldierBigSpoonsInit`, `Disable`)
                        EntFire(`TripleTrolldierCrashoutRelay`, `Trigger`)
                      "
            }
		}
		WaveSpawn // Boss - Larry
		{
			Name "Wave17_Boss-Larry"
			Where spawnbot_boss
			TotalCount 1
			MaxActive 1
			SpawnCount 1
			WaitBeforeStarting 12.6
			WaitBetweenSpawns 0
			TotalCurrency 100

			TFBot
			{
				Template MainBoss_Larry
				FireInput
                {
                    Target !self
                    Action $TeleportToEntity
                    Param spawnbot_target_electricmine2
                    Delay 0.1
                    Repeats 1
                    Cooldown -1
                }
			}

            FirstSpawnOutput
            {
                Target BigNet
                Action RunScriptCode
                Param "
                        MusicSystemMent.SetMusicTrack(`#triple_threat_trolldier_boss_theme.mp3`);
                        EntFire(`TripleTrolldierCrashoutRelay`, `Enable`)
                      "
            }
            DoneOutput
            {
                Target BigNet
                Action RunScriptCode
                Param "
                        EntFire(`TrolldierGigaShockwaveInit`, `Disable`)
                        EntFire(`TripleTrolldierCrashoutRelay`, `Trigger`)
                      "
            }
		}
		WaveSpawn // Boss - Harry
		{
			Name "Wave17_Boss-Harry"
			Where spawnbot_boss
			TotalCount 1
			MaxActive 1
			SpawnCount 1
			WaitBeforeStarting 12.7
			WaitBetweenSpawns 0
			TotalCurrency 100

			TFBot
			{
				Template MainBoss_Harry
				FireInput
                {
                    Target !self
                    Action $TeleportToEntity
                    Param spawnbot_target_electricmine1
                    Delay 0.1
                    Repeats 1
                    Cooldown -1
                }
			}
            DoneOutput
            {
                Target BigNet
                Action RunScriptCode
                Param "
                        EntFire(`TrolldierBigSpoonsInit`, `Disable`)
                        EntFire(`TripleTrolldierCrashoutRelay`, `Trigger`)
                      "
            }
		}
    }
	Wave // Main Boss - Overclocked Dave Reborn
    {
        InitWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`wave_init_arena_terrorlict_relay`, `Trigger`, null, 6)
                    Convars.SetValue(`sig_mvm_beggar_stun_nerf`, 1)
                    EntFire(`BossRushPlayerSpawn`, `Disable`)
                    EntFire(`howmanyofthemleft`,`SetText`,`2?`, 0.5)
					IncludeScript(`tankextensions_main`, getroottable())
					IncludeScript(`tankextensions/combattank`, getroottable())
                	IncludeScript(`tankextensions/combattank_weapons/rocketpod`, getroottable())
                	IncludeScript(`tankextensions/combattank_weapons/railgun`, getroottable())

                    TankExt.CreateLoopPaths({
                        tank_loop = [
                            Vector(13504, 5440, -256)    // tank_path_1
							Vector(12992, 5440, -1088)    // tank_path_2
							Vector(12672, 5312, -1088)    // tank_path_3
							Vector(12480, 5120, -1088)    // tank_path_4
							Vector(12416, 4800, -1088)    // tank_path_5
							Vector(12480, 3712, -1024)    // tank_path_6
							Vector(12416, 3520, -1024)    // tank_path_7
							Vector(12160, 3392, -1024)    // tank_path_8
							Vector(11904, 3392, -1024)    // tank_path_9
							Vector(11776, 3456, -1024)    // tank_path_10
							Vector(11648, 3584, -1024)    // tank_path_11
							Vector(11584, 3904, -1024)    // tank_path_12
							Vector(11712, 4352, -1024)    // tank_path_13
							Vector(11712, 4928, -1088)    // tank_path_14
							Vector(11840, 5248, -1088)    // tank_path_15
							Vector(12032, 5376, -1088)    // tank_path_16
							Vector(12288, 5376, -1088)    // tank_path_17
							Vector(12480, 5120, -1088)    // tank_path_18
                        ]
                    })

					TankExt.SetValueOverrides({
                        COMBATTANK_ROTATE_SPEED_DEFAULT = 1.4   // default: 0.8
                        COMBATTANK_MAX_RANGE = 2000            // default: 1400
                    })

                    if (MusicSystemMent.MasterEntity == null || !MusicSystemMent.MasterEntity.IsValid())
					{
						MusicSystemMent.ResetAll();
						MusicSystemMent.HookByName(`bignet`);
					}
					MusicSystemMent.SetMusicTrack(`#mentrillum/mvm/music/bossrush/apocalyptic_reboot.wav`, 2.0, 2.0, 0.75);
                  "
        }
        StartWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`wave_start_relay`, `Trigger`)
                    EntFire(`BossRushPlayerSpawn`, `Enable`)
                  "
        }
        DoneOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`wave_finished_relay`, `Trigger`)
                    EntFire(`boss_rush_spawn_teleport_relay`, `Trigger`, null, 5)
                  "
        }
        
		CustomWaveNumber 16
		CustomMaxWaveNumber 0
        RedTeamWipeCausesWaveLoss 1

        WaveSpawn
        {
            Name "teleporthotfix"
            WaitBeforeStarting 5.1

            FirstSpawnOutput
            {
                Target BigNet
                Action RunScriptCode
                Param "
                        EntFire(`arena_teleport_relay`, `Trigger`)
                        MusicSystemMent.SetMusicTrack(``, 2.0, 2.0);
						EntFire(`tf_gamerules`, `PlayVO`, `boss_incoming.wav`, 2.4)
                      "
            }
        }

        WaveSpawn // Boss
        {
            Name "Wave18_Boss-OverclockedDaveReborn"
            Where spawnbot_boss
            TotalCount 1
            MaxActive 1
            SpawnCount 1
            WaitBeforeStarting 12.5
            WaitBetweenSpawns 0
            TotalCurrency 100

            TFBot
            {
                Template DaveReborn
                Action Mobber
            }
            FirstSpawnOutput
            {
                Target BigNet
                Action RunScriptCode
                Param "
                        MusicSystemMent.SetMusicTrack(`#launch_sequence_v2.mp3`);
                      "
            }
			DoneOutput
			{
				Target BigNet
				Action RunScriptCode
				Param "
						EntFire(`pop_interface`, `$KillWaveSpawn`, `Wave18_Support-Soldiers`)
						EntFire(`pop_interface`, `$KillWaveSpawn`, `Wave18_Support-ArmoredBatScouts`)
						EntFire(`pop_interface`, `$FinishWaveSpawn`, `Wave18_Support-Soldiers`)
						EntFire(`pop_interface`, `$FinishWaveSpawn`, `Wave18_Support-ArmoredBatScouts`)
					  "
			}
        }
        WaveSpawn // Tank # HP
        {
            Name "getdisablednoob"
            WaitForAllDead ""
            TotalCount 1
            MaxActive 1
            SpawnCount 1
            WaitBeforeStarting 0
            WaitBetweenSpawns 0
            StartDisabled 1
            TotalCurrency 0
        
            Tank
            {
                Name "combattank|rocketpod_homing|railgun"
                StartingPathTrackNode "tank_loop_1"
                ClassIcon 	tank_combat_railgun_homingburst
                SpawnTemplate teleforbossafterdeath
                Health 30000
                Speed 75
                Skin 0
        
                OnKilledOutput 
                {
                    Target "aftercombattank"
                    Action Trigger
                }
                OnBombDroppedOutput
                {
                    Target boss_deploy_relay
                    Action Trigger
                }
            }
        }

		WaveSpawn
		{
			Name "Wave18_DaveDead"
			WaitForAllDead "Wave18_Boss-OverclockedDaveReborn"
			WaitBeforeStarting 12
		}
        WaveSpawn // Support Soldiers
        {
            Name "Wave18_Support-Soldiers"
            Where spawnbot_support
            Support 1
            TotalCount 100
            MaxActive 4
            SpawnCount 1
            WaitBeforeStarting 20
            WaitBetweenSpawns 5
            TotalCurrency 100

            TFBot
            {
                Class Soldier
                Skill Expert
                Action Mobber
            }
        }
        WaveSpawn // Support Armored Bat Scouts
        {
            Name "Wave18_Support-ArmoredBatScouts"
            Where spawnbot_support
            Support 1
            TotalCount 100
            MaxActive 2
            SpawnCount 1
            WaitBeforeStarting 20
            WaitBetweenSpawns 8
            TotalCurrency 100

            TFBot
            {
                Name "Armored Bat Scout"
                Template T_TFBot_Scout_Melee
                ClassIcon scout_bat_nys_armored
                Scale 1.4
                Health 900
                Attributes DisableDodge
                Action Mobber
            }
        }
    }
