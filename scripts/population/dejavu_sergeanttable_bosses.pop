    {
        //// MAIN BOSSES ////

        // Major Shocks (from temu)
        T_TFBot_Shocks_Realnt
        {
            Name "Major Shocks (from temu)"
            Class Soldier
            ClassIcon soldier_hellmet_lite
            Skill Expert
            Health 100000
            Scale 2.5
            Attributes MiniBoss
            Attributes UseBossHealthBar
            Attributes HoldFireUntilFullReload
            Attributes DisableDodge
            Attributes AlwaysCrit
            ExtAttr IgnoreBuildings
            UseMeleeThreatPrioritization 1
            Action Mobber

            UseHumanAnimations 1

            Item "The Direct Hit"
            Item "The Hellmet"
            Item "Big Steel Jaw of Summer Fun"
            Item "Taunt: Yeti Smash"

            SpawnTemplate
            {
                Name "bossstuffs"
                Bone bip_pelvis_0
            }

            CharacterAttributes
            {
                "move speed bonus"	0.5
                "damage force reduction" 0.4
                "airblast vulnerability multiplier" 0.4
                "override footstep sound set" 3
                "airblast vertical vulnerability multiplier" 0.1
                "cancel falling damage" 1
                "always allow taunt" 1
                "displace touched enemies" 1
            }

            AddCond
            {
                Index 51
                Duration 4
            }
            Taunt
            {
                Name "Primary"
                Delay 0.5
                Repeats 1
                Cooldown -1
            }
            FireInput
            {
                Target "tf_gamerules"
                Action PlayVO
                Param vo/mvm/mght/soldier_mvm_m_directhittaunt02
                Delay 0.5
                Repeats 1
                Cooldown -1
            }

            FireInput
            {
                Target "TemuAttackPool"
                Action PickRandomShuffle
                Delay 3
                Repeats 1
                Cooldown -1
            }

            FireInput
            {
                Target "NEEDTHETOILET"
                Action Trigger
                Delay 30
                Repeats 1
                Cooldown -1
            }

            FireInput
            {
                Target BigNet
                Action RunScriptCode
                Param "MusicSystemMent.SetMusicTrack(``, 2.0, 2.0);"
                Delay 30
                Repeats 1
                Cooldown -1
            }

            EventChangeAttributes
            {
                TemuBarrage [$SIGSEGV]
                {
                    Item "TF_WEAPON_ROCKETLAUNCHER"
                    WeaponRestrictions PrimaryOnly

                    ItemAttributes
                    {
                        ItemName "TF_WEAPON_ROCKETLAUNCHER"
                        "damage bonus" 1.5
                        "fire rate bonus" 0.2
                        "faster reload rate" 0.001
                        "clip size upgrade atomic" 26
                        "projectile speed decreased" 0.4
                        "projectile spread angle penalty" 5
                    }

                    FireInput
                    {
                        Target "TemuAttackPool"
                        Action PickRandomShuffle
                        Delay 6
                        Repeats 1
                        Cooldown -1
                    }
                }
                TemuHoming [$SIGSEGV]
                {
                    Item "The Liberty Launcher"
                    WeaponRestrictions PrimaryOnly

                    ItemAttributes
                    {
                        ItemName "The Liberty Launcher"

                        "damage bonus" 1.25
                        "fire rate bonus" 0.002
                        "faster reload rate" 0.1
                        "clip size upgrade atomic" 12
                        "projectile speed decreased" 0.75
                        "projectile spread angle penalty" 120
                        "add cond when active" 36
                    }

                    HomingRockets
                    {
                        IgnoreDisguisedSpies	1
                        IgnoreStealthedSpies	1
                        RocketSpeed	0.01
                        TurnPower	105
                        MaxAimError	150
                        AimTime	1.5
                        Acceleration	30000
                        AccelerationTime	0.1
                        AccelerationStartTime	1.5
                        Gravity	0
                        FollowCrosshair	0
                    }

                    FireInput
                    {
                        Target "TemuAttackPool"
                        Action PickRandomShuffle
                        Delay 6
                        Repeats 1
                        Cooldown -1
                    }
                }
                TemuNuke [$SIGSEGV]
                {
                    Item "The Black Box"
                    WeaponRestrictions PrimaryOnly

                    ItemAttributes
                    {
                        ItemName "The Black Box"
                        "damage bonus" 3
                        "blast radius increased" 2
                        "fire rate bonus" 2.5
                        "faster reload rate" 0.001
                    }

                    FireInput
                    {
                        Target "TemuAttackPool"
                        Action PickRandomShuffle
                        Delay 6
                        Repeats 1
                        Cooldown -1
                    }
                }
                TemuShotty [$SIGSEGV]
                {
                    Item "TF_WEAPON_SHOTGUN_SOLDIER"
                    WeaponRestrictions SecondaryOnly

                    ItemAttributes
                    {
                        ItemName "TF_WEAPON_SHOTGUN_SOLDIER"
                        "fire rate bonus" 0.1
                        "faster reload rate" 0.2
                        "clip size bonus" 2
                        "auto fires when full" 1
                        "auto fires full clip" 1
                    }

                    FireInput
                    {
                        Target "TemuAttackPool"
                        Action PickRandomShuffle
                        Delay 6
                        Repeats 1
                        Cooldown -1
                    }
                }
                TemuGroundPound [$SIGSEGV]
                {
                    FireInput
                    {
                        Target "TemuGroundPoundAttack"
                        Action Trigger
                        Delay 0
                        Repeats 1
                        Cooldown -1
                    }

                    FireInput
                    {
                        Target !self
                        Action $ChangeAttributes
                        Param TemuGroundPoundIdle
                        Delay 2.1
                        Repeats 1
                        Cooldown -1
                    }
                }
                TemuGroundPoundIdle [$SIGSEGV]
                {
                    FireInput
                    {
                        Target "TemuAttackPool"
                        Action PickRandomShuffle
                        Delay 10
                        Repeats 1
                        Cooldown -1
                    }
                }
                TemuPassive1 [$SIGSEGV]
                {
                    Attributes IgnoreEnemies

                    Addcond 14

                    CharacterAttributes
                    {
                        "no_attack" 1
                        "no_jump" 1
                    }
                }
                TemuPassive2 [$SIGSEGV]
                {
                    Attributes IgnoreEnemies

                    Addcond 14

                    CharacterAttributes
                    {
                        "no_attack" 1
                        "no_jump" 1
                    }

                    InterruptAction
                    {
                        Target "-6143 -5249 -712"
                        Delay 0
                        Repeats 99999
                        Distance 8
                        Duration 4
                        Cooldown 0.5
                    }
                }
            }
        }

