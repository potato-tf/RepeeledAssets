	Wave // Boss Gauntlet - Bigheaded Behemoth, TON 618 Black Hole Pyro, then General Bomber & King Burst
	{
		InitWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`wave_init_arena_bonkplant_relay`, `Trigger`, null, 6)
                    Convars.SetValue(`sig_mvm_beggar_stun_nerf`, 1)
                    EntFire(`BossRushPlayerSpawn`, `Disable`)
                    EntFire(`howmanyofthemleft`,`SetText`,`16`, 0.5)
                    if (!(`music_system_ment` in getroottable()))
                    {
                        IncludeScript(`music_system_ment`, getroottable())
                    }

                    if (MusicSystemMent.MasterEntity == null || !MusicSystemMent.MasterEntity.IsValid())
					{
						MusicSystemMent.ResetAll();
						MusicSystemMent.HookByName(`bignet`);
					}
					MusicSystemMent.SetMusicTrack(`#mentrillum/mvm/music/bossrush/the_arena_rest_area.wav`, 2.0, 2.0, 0.65);
                  "
        }
        StartWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`wave_start_relay`, `Trigger`)
                    EntFire(`BossRushPlayerSpawn`, `Enable`)
                  "
        }
        DoneOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`wave_finished_relay`, `Trigger`)
                    EntFire(`boss_rush_spawn_teleport_relay`, `Trigger`, null, 5)
                  "
        }
		
        CustomMaxWaveNumber 0
        RedTeamWipeCausesWaveLoss 1

        WaveSpawn
        {
            Name "teleporthotfix"
            WaitBeforeStarting 5.1

            FirstSpawnOutput
            {
                Target BigNet
                Action RunScriptCode
                Param "
                        EntFire(`arena_teleport_relay`, `Trigger`)
						EntFire(`tf_gamerules`, `PlayVO`, `boss_incoming.wav`, 2.4)
                        MusicSystemMent.SetMusicTrack(``, 2.0, 2.0);
                      "
            }
        }

        // Boss 1 - Bigheaded Behemoth
		WaveSpawn
		{
			Name "Wave2_Boss1-BigheadedBehemoth"
            Where spawnbot_boss
            TotalCount 1
            MaxActive 1
            SpawnCount 1
            WaitBeforeStarting 12.5
            WaitBetweenSpawns 0
            TotalCurrency 50

            TFBot
            {
                Template T_TFBot_Fat_Boss_Heavy_Champ
                Action Mobber
            }

            FirstSpawnOutput
            {
                Target BigNet
                Action RunScriptCode
                Param "
                        MusicSystemMent.SetMusicTrack(`#mentrillum/mvm/music/bossrush/true_arena_showdown.wav`);
                      "
            }
			DoneOutput
            {
                Target BigNet
                Action RunScriptCode
                Param "
                        EntFire(`pop_interface`, `$PauseWaveSpawn`, `Wave2_Support-GRUHeavies`)
                        EntFire(`pop_interface`, `$KillWaveSpawn`, `Wave2_Support-GRUHeavies`)
                        EntFire(`arena_bonkplant_boss_spawn_relay`, `Trigger`, 2.5)
                        EntFire(`tf_gamerules`, `PlayVO`, `boss_incoming.wav`, 2.5)
                      "
            }
		}
		WaveSpawn // Support GRU Heavies
		{
			Name "Wave2_Support-GRUHeavies"
			Where spawnbot_support
			Support 1
			TotalCount 50
			MaxActive 3
			SpawnCount 1
			WaitBeforeStarting 17.5
			WaitBetweenSpawns 4
			TotalCurrency 50

			TFBot
			{
				Name "Lightweight Champ"
                Template T_TFBot_Heavyweapons_Heavyweight_Champ_Fast
				Skill Hard
                Action Mobber
			}
		}

		// Boss 2 - TON 618 Black Hole Pyro
		WaveSpawn
		{
			Name "Wave2_Boss2-TON618BlackHolePyro"
            WaitForAllDead "Wave2_Boss1-BigheadedBehemoth"
			Where spawnbot_boss
			TotalCount 1
			MaxActive 1
			SpawnCount 1
			WaitBeforeStarting 7.5
			WaitBetweenSpawns 0
			TotalCurrency 50

