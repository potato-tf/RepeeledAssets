// Deja Vu, Deja Mort - A Boss Rush Mission

//// STANDARD POPFILE IMPORTS ////
#base robot_giant.pop
#base robot_standard.pop

//// BOSS POPFILE IMPORTS ////
#base dejavu_bazooks_bosses.pop
#base dejavu_chaosmystery_bosses.pop
#base dejavu_claudz_bosses.pop
#base dejavu_cookiecat_bosses.pop
#base dejavu_mentrillum_bosses.pop
#base dejavu_package_bosses.pop
#base dejavu_sergeanttable_bosses.pop
#base dejavu_sleeeepykai_bosses.pop
#base dejavu_sntr_bosses.pop
#base dejavu_thefat_bosses.pop
#base dejavu_wiz2_bosses.pop
#base dejavu_wooper_bosses.pop
#base dejavu_zombief1ghter_bosses.pop

WaveSchedule
{
    StartingCurrency 3000
    RespawnWaveTime 0
    FixedRespawnWaveTime Yes
    AddSentryBusterWhenDamageDealtExceeds 3000
    AddSentryBusterWhenKillCountExceeds 10

    WaveStartCountdown 7

    BodyPartScaleSpeed 10

    ForceRedMoney 1
    TextPrintTime 0

    ConchHealthOnHit 0.175

    //// DISABLED SOUNDS ////

    DisableSound "Announcer.MVM_Wave_End"
    DisableSound "Announcer.MVM_Final_Wave_End"	
	DisableSound "Announcer.MVM_Bonus"
    DisableSound "Announcer.MVM_Get_To_Upgrade"

    DisableSound "music.mvm_start_wave"
    DisableSound "music.mvm_start_last_wave"					   
	DisableSound "music.mvm_start_mid_wave"						   
	DisableSound "music.mvm_start_tank_wave"
    DisableSound "music.mvm_end_wave"
    DisableSound "music.mvm_end_last_wave"						   
	DisableSound "music.mvm_end_mid_wave"						   
	DisableSound "music.mvm_end_tank_wave"						   

    //// PRECACHES ////

    // Sound Precaches
	PrecacheSound "boss_incoming.wav"
    PrecacheSound "mainbosstheme1.mp3"
	PrecacheSound "first_phase_supercharged.mp3"
	PrecacheSound "expert_boss_theme.mp3"
	PrecacheSound "overprodshowdownv2.mp3"
	PrecacheSound "launch_sequence_v2.mp3"
    PrecacheSound "triple_threat_trolldier_boss_theme.mp3"

    PrecacheSound "mentrillum/mvm/music/bossrush/boss_blitz_galaxy.wav"
	PrecacheSound "mentrillum/mvm/music/bossrush/internal_struggle.wav"
	PrecacheSound "mentrillum/mvm/music/bossrush/lone_swordsman_phase1.wav"
	PrecacheSound "mentrillum/mvm/music/bossrush/lone_swordsman_phase2.wav"
	PrecacheSound "mentrillum/mvm/music/bossrush/mini_boss_rush_2.wav"
	PrecacheSound "mentrillum/mvm/music/bossrush/slimy_spring_galaxy.wav"
	PrecacheSound "mentrillum/mvm/music/bossrush/the_arena_rest_area.wav"
	PrecacheSound "mentrillum/mvm/music/bossrush/true_arena_showdown.wav"
	PrecacheSound "mentrillum/mvm/music/bossrush/where_the_true_enemy_lies.wav"
    PrecacheSound "mentrillum/mvm/music/bossrush/apocalyptic_reboot.wav"
    PrecacheSound "mentrillum/mvm/music/bossrush/hallway_back_to_the_origin.wav"
    PrecacheSound "mentrillum/mvm/music/bossrush/hypercharging_supernova.wav"

    PrecacheSound "tmc_fat_boss_intro.mp3"
    PrecacheSound "tmc_fat_boss_loop.mp3"
    PrecacheSound "burnedatthestake.mp3"

    PrecacheSound "combattankphasestart.mp3"
    PrecacheSound "start_beam_whatever.mp3"
    PrecacheSound "laser_related_attack.mp3"
    PrecacheSound "swordsman_spin_attack.wav"

    PrecacheSound "major_shocks_spin.mp3"
    PrecacheSound "megalaser_chargeup.wav"
    PrecacheSound "megalaser_fire.wav"
    PrecacheSound "megalaser_fireloop.wav"
    PrecacheSound "boss_charging_his_shit.mp3"
    PrecacheSound "trolldier_crashout.wav"

    //// POINT TEMPLATES ////

    PointTemplates 
    {
        //// CORE BOSS RUSH LOGIC ////
        BossRushMapLogic
        {
            OnSpawnOutput
            {
                Target tf_gamerules
                Action Runscriptcode
                Param "
                    IncludeScript(`claudz_logic_v3`)
                "
            }
            prop_dynamic
            {
                "targetname" "tvtime"
                "model"      "models/props_manor/table_01.mdl"
                "origin"     "37 -11092 -1222"
                "modelscale" "2"
                "disableshadows" "1"
                "disablebonefollowers" "1"
                "solid" "6"
            }
            prop_dynamic
            {
                "targetname" "tvtime2"
                "model"      "models/passtime/tv/passtime_tv_noplug.mdl"
                "origin"     "37 -11092 -1160"
                "modelscale" "2"
                "disableshadows" "1"
                "disablebonefollowers" "1"
                "solid" "6"
            }
            point_worldtext
            {
                "targetname" "howmanyencounters"
                "message" "Encounters:"
                "font" "1"
                "textsize" "5"
                "color" "255 255 255 255"
                "orientation" "0"
                "origin" "10 -11110 -1128"
                "angles" "0 90 0"
            }
            point_worldtext
            {
                "targetname" "howmanyofthemleft"
                "message" "17"
                "font" "1"
                "textsize" "20"
                "color" "255 255 255 255"
                "orientation" "0"
                "origin" "13 -11110 -1145"
                "angles" "0 90 0"
            }
            logic_relay // Wave Finish Teleporter
            {
                "targetname" "boss_rush_spawn_teleport_relay"
                "OnTrigger" "@f@filter_red@player,$TeleportToEntity,skybox_sun_target,0,-1"
                "OnTrigger" "portal_teleport_fade,Fade,,0,-1"
                "OnTrigger" "portal_teleport_sound,PlaySound,,0,-1"
                "OnTrigger" "obj_sentrygun*,RemoveHealth,10000,0,-1"
                "OnTrigger" "obj_dispenser*,RemoveHealth,10000,0,-1"
                "OnTrigger" "obj_teleporter*,RemoveHealth,10000,0,-1"
            }

            // Universal Filters
            filter_activator_class // Is a Player
            {
                "targetname" "filter_is_player"
                "Negated" "0"
                "filterclass" "player"
            }
            filter_multi // Is a Red Player
            {
                "targetname" "filter_is_red_player"
                "Negated"	"0"
                "FilterType" "0"			
                "Filter01"   "filter_redteam"
                "Filter02"   "filter_is_player"
            }
            filter_tf_condition // Medigun Uber Filter
            {
                "targetname" "filter_is_not_ubered"
                "Negated"	"1"
                "condition"  "5" //medigun uber
            }
            filter_tf_condition // Canteen Uber Filter
            {
                "targetname" "filter_is_not_ubered2"
                "Negated"	"1"
                "condition"  "52" //canteen uber
            }
            filter_tf_condition // MVM Spawn Uber Filter
            {
                "targetname" "filter_is_not_ubered3"
                "Negated"	"1"
                "condition"  "51" //hidden uber
            }
            filter_tf_condition // Wheel of Fate Uber ilter
            {
                "targetname" "filter_is_not_ubered4"
                "Negated"	"1"
                "condition"  "57" //WoF uber
            }
            filter_multi // Is an Un-Ubered Red Player
            {
                "targetname" "filter_redteam_nouber"
                "Negated"	"0"
                "FilterType" "0" //and				
                "Filter01"   "filter_redteam"
                "Filter02"   "filter_is_not_ubered"
                "Filter03"   "filter_is_not_ubered2"
                "Filter04"   "filter_is_not_ubered3"
                "Filter05"   "filter_is_not_ubered4"
                "Filter06"   "filter_is_player"
            }
            filter_multi // Is an Un-Ubered Player
            {
                "targetname" "filter_nouber"
                "Negated"	"0"
                "FilterType" "0"
                "Filter01"   "filter_is_not_ubered"
                "Filter02"   "filter_is_not_ubered2"
                "Filter03"   "filter_is_not_ubered3"
                "Filter04"   "filter_is_not_ubered4"
                "Filter05"   "filter_is_player"
            }

            logic_relay
            {
                "targetname" "BossRushPlayerSpawn"
                "spawnflags" "2"
                "startdisabled" "1"

                "OnTrigger" "!activator,$Addcond,51 8,0,-1"
                "OnTrigger" "!activator,$Addcond,32 8,0,-1"
                "OnTrigger" "!activator,$DisplayTextHint,You will be teleported in 5 seconds,0,-1"
            }
        }
        BossRushSpecialSpawnLocation
        {
            RemoveIfKilled "arena_unique_boss_spawn_tesla"

            info_particle_system
            {
                "targetname" "arena_unique_boss_spawn_particle"
                "effect_name" "charge_up"
                "start_active" "0"
            }
            point_tesla
            {
                "targetname" "arena_unique_boss_spawn_tesla"
                "texture" "sprites/physbeam.vmt"
                "beamcount_min" 3
                "beamcount_max" 9
                "interval_min" 0.05
                "interval_max" 0.05
                "lifetime_min" 0.15
                "lifetime_max" 0.15
                "thick_min" 4
                "thick_max" 10
                "m_bOn" 0
                "m_Color" "255 32 32"
                "m_flRadius" 550
            }

            OnSpawnOutput
            {
                Target "arena_unique_boss_spawn_tesla"
                Action TurnOn
                Delay 0
                Repeats 1
                Cooldown -1
            }
            OnSpawnOutput
            {
                Target "arena_unique_boss_spawn_particle"
                Action Start
                Delay 0.5
                Repeats 1
                Cooldown -1
            }
            OnSpawnOutput
            {
                Target "arena_unique_boss_spawn_tesla"
                Action TurnOff
                Delay 5
                Repeats 1
                Cooldown -1
            }
            OnSpawnOutput
            {
                Target "arena_unique_boss_spawn_particle"
                Action Stop
                Delay 5
                Repeats 1
                Cooldown -1
            }
            OnSpawnOutput
            {
                Target "arena_unique_boss_spawn_tesla"
                Action Kill
                Delay 5.5
                Repeats 1
                Cooldown -1
            }
        }

        BossRushPlayerSpawnInvuln
        {
            OnSpawnOutput
            {
                Target "BossRushPlayerSpawn"
                Action "Trigger"
                Delay -1
                Repeats 1
                Cooldown -1
            }
        }

        //// BOSS POINT-TEMPLATE FIXES ////

        // Nemesis Shell Teleporting
        NemesisShellTeleport
        {
            KeepAlive 1
            info_target
            {
                "targetname" "nemesis_shell_teleport_target"
                "origin" "0 0 0"
            }

            OnParentKilledOutput
            {
                Target nemesis_shell_teleport_target
                Action Kill
                Delay 1
            }
        }

        // Mini Riders for Bad to the Bone
        SmallRider
		{
			OnSpawnOutput
			{
				Target "smallrider_idle"
				Action "PlaySound"
			}
			ambient_generic
			{
				targetname smallrider_idle
				health 10 // this is volume
				pitch 90
				radius 3500
				message "Taunt.MopedForward"
				sourceentityname rider_soundsource
			}
			prop_dynamic // noisebox
			{
				angles "0 0 0"
				origin "-70 25 80"
				disableshadows 0
				model "models\empty.mdl"
				rendermode 10
				solid 0
				targetname rider_soundsource
			}
		}
    }

    //// SPAWNED POINTTEMPLATES ////

    PlayerSpawnTemplate BossRushPlayerSpawnInvuln

    SpawnTemplate BossRushMapLogic

    //// BALANCE CHANGES ////

    PlayerAttributes
    {
        Pyro
        {
            "damage bonus" 1.25
        }
        Heavyweapons
        {
            "damage bonus" 0.8
        }
    }
    ItemAttributes
    {
        ItemName "The Ubersaw"
        "add uber charge on hit" 0.095
    }

    //// MISSION BOTS ////

    Mission // Sentry Buster
    {
        Objective DestroySentries
        Where spawnbot_support
        BeginAtWave 1
		RunForThisManyWaves 15
		InitialCooldown 30
		CooldownTime 30
		DesiredCount 1
		
		TFBot
		{
			Template T_TFBot_SentryBuster
		}
    }
    Mission // Sentry Buster
    {
        Objective DestroySentries
        Where spawnbot_support
        BeginAtWave 17
		RunForThisManyWaves 2
		InitialCooldown 30
		CooldownTime 30
		DesiredCount 1
		
		TFBot
		{
			Template T_TFBot_SentryBuster
		}
    }

    //// WAVES ////

    // INTERMEDIATE GAUNTLET //

	Wave // Mini Boss - Field General OR Explosive Surprise OR The Fallen Patrol Chiefs
	{
		InitWaveOutput
		{
			Target BigNet
			Action RunScriptCode
			Param "
					Convars.SetValue(`sig_mvm_beggar_stun_nerf`, 1)
					EntFire(`BossRushPlayerSpawn`, `Disable`)
                    EntFire(`howmanyofthemleft`,`SetText`,`17`, 0.5)

                    if(!(`milknerf`) in getroottable())
                    {
                        IncludeScript(`milknerf`, getroottable())
                    }
					if (!(`alternatewaves` in getroottable()))
					{
						IncludeScript(`alternatewaves`, getroottable());
					}
					if (!(`mvm_mind_bloom_arena_rng` in getroottable()))
					{
						IncludeScript(`mvm_mind_bloom_arena_rng`, getroottable());
					}
					if (!(`music_system_ment` in getroottable()))
					{
						IncludeScript(`music_system_ment`, getroottable());
					}
					PrecacheSound(`#mainbosstheme1.mp3`);
					PrecacheSound(`#first_phase_supercharged.mp3`)
					PrecacheSound(`#expert_boss_theme.mp3`);
					PrecacheSound(`#overprodshowdownv2.mp3`);
					PrecacheSound(`#launch_sequence_v2.mp3`);
					PrecacheSound(`#triple_threat_trolldier_boss_theme.mp3`);
					PrecacheSound(`#mentrillum/mvm/music/bossrush/boss_blitz_galaxy.wav`);
					PrecacheSound(`#mentrillum/mvm/music/bossrush/internal_struggle.wav`);
					PrecacheSound(`#mentrillum/mvm/music/bossrush/lone_swordsman_phase1.wav`);
					PrecacheSound(`#mentrillum/mvm/music/bossrush/lone_swordsman_phase2.wav`);
					PrecacheSound(`#mentrillum/mvm/music/bossrush/mini_boss_rush_2.wav`);
					PrecacheSound(`#mentrillum/mvm/music/bossrush/slimy_spring_galaxy.wav`);
					PrecacheSound(`#mentrillum/mvm/music/bossrush/the_arena_rest_area.wav`);
					PrecacheSound(`#mentrillum/mvm/music/bossrush/true_arena_showdown.wav`);
					PrecacheSound(`#mentrillum/mvm/music/bossrush/where_the_true_enemy_lies.wav`);
					PrecacheSound(`#mentrillum/mvm/music/bossrush/apocalyptic_reboot.wav`);
					PrecacheSound(`#mentrillum/mvm/music/bossrush/hallway_back_to_the_origin.wav`);
					PrecacheSound(`#mentrillum/mvm/music/bossrush/hypercharging_supernova.wav`);
					MusicSystemMent.ResetAll();
					MusicSystemMent.HookByName(`bignet`);

					MindBloomRNG.AddRNGArena(`wave_init_arena_lostvalley_relay`, `Wave1_FieldGeneral`);
					MindBloomRNG.AddRNGArena(`wave_init_arena_coastrock_relay`, `Wave1_ExplosiveSurprise`);
					MindBloomRNG.AddRNGArena(`wave_init_arena_spyfactory_relay`, `Wave1_FallenPatrolChiefs`);
					MindBloomRNG.InitRNGArena();

					AlternateWaves.bTrackIcons = false;
					AlternateWaves.ClearWaveIcons();

					switch (MindBloomRNG.GlobalIndex)
					{
						case 0:
						{
							AlternateWaves.AddWaveIcons([
								[`soldier_burstfire_conch`, 1, MVM_CLASS_FLAG_MINIBOSS],
								[`soldier_shovel`, 1, MVM_CLASS_FLAG_NORMAL | MVM_CLASS_FLAG_SUPPORT],
								[`heavy_shotgun`, 1, MVM_CLASS_FLAG_NORMAL | MVM_CLASS_FLAG_SUPPORT]
							])
							break;
						}

                        case 1:
						{   
							AlternateWaves.AddWaveIcons([
								[`demoman_sandman_chief`, 1, MVM_CLASS_FLAG_MINIBOSS],
								[`soldier`, 1, MVM_CLASS_FLAG_NORMAL | MVM_CLASS_FLAG_SUPPORT],
								[`scout_bat_nys`, 1, MVM_CLASS_FLAG_NORMAL | MVM_CLASS_FLAG_SUPPORT]
							])
							break;
						}

						case 2:
						{   
							AlternateWaves.AddWaveIcons([
								[`heavy_robot_nys`, 1, MVM_CLASS_FLAG_MINIBOSS],
								[`demo_robot_nys`, 1, MVM_CLASS_FLAG_MINIBOSS],
								[`boss_death_pyro`, 1, MVM_CLASS_FLAG_MINIBOSS],
								[`demoknight`, 1, MVM_CLASS_FLAG_NORMAL | MVM_CLASS_FLAG_SUPPORT]
							])
							break;
						}
					}
				  "
		}
		StartWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`wave_start_relay`, `Trigger`)
                    EntFire(`BossRushPlayerSpawn`, `Enable`)

                    AlternateWaves.ClearWaveIcons();

                    switch (MindBloomRNG.GlobalIndex)
                    {
                        case 0:
						{
							AlternateWaves.AddWaveIcons([
								[`soldier_burstfire_conch`, 1, MVM_CLASS_FLAG_MINIBOSS],
								[`soldier_shovel`, 1, MVM_CLASS_FLAG_NORMAL | MVM_CLASS_FLAG_SUPPORT],
								[`heavy_shotgun`, 1, MVM_CLASS_FLAG_NORMAL | MVM_CLASS_FLAG_SUPPORT]
							])
							break;
						}

                        case 1:
						{   
							AlternateWaves.AddWaveIcons([
								[`demoman_sandman_chief`, 1, MVM_CLASS_FLAG_MINIBOSS],
								[`soldier`, 1, MVM_CLASS_FLAG_NORMAL | MVM_CLASS_FLAG_SUPPORT],
								[`scout_bat_nys`, 1, MVM_CLASS_FLAG_NORMAL | MVM_CLASS_FLAG_SUPPORT]
							])
							break;
						}
                        
						case 2:
						{   
							AlternateWaves.AddWaveIcons([
								[`heavy_robot_nys`, 1, MVM_CLASS_FLAG_MINIBOSS],
								[`demo_robot_nys`, 1, MVM_CLASS_FLAG_MINIBOSS],
								[`boss_death_pyro`, 1, MVM_CLASS_FLAG_MINIBOSS],
								[`demoknight`, 1, MVM_CLASS_FLAG_NORMAL | MVM_CLASS_FLAG_SUPPORT]
							])
							break;
						}
                    }

                    MindBloomRNG.StartRNGArena();
                  "
        }
        DoneOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`wave_finished_relay`, `Trigger`)
                    EntFire(`boss_rush_spawn_teleport_relay`, `Trigger`, null, 5)

                    AlternateWaves.bTrackIcons = true;
                  "
        }

        CustomMaxWaveNumber 0
        RedTeamWipeCausesWaveLoss 1

        WaveSpawn
        {
            Name "teleporthotfix"
            WaitBeforeStarting 5.1

            FirstSpawnOutput
            {
                Target BigNet
                Action RunScriptCode
                Param "
                        EntFire(`arena_teleport_relay`, `Trigger`)
						EntFire(`tf_gamerules`, `PlayVO`, `boss_incoming.wav`, 2.4)
                        MusicSystemMent.SetMusicTrack(``, 2.0, 2.0);
                      "
            }
        }

		//// Field General ////
		WaveSpawn
		{
			Name "Wave1_FieldGeneral"
			StartDisabled 1
		}
		WaveSpawn // Boss
        {
            Name "Wave1_Boss-FieldGeneral"
			WaitForAllSpawned "Wave1_FieldGeneral"
            Where spawnbot_boss
            TotalCount 1
            MaxActive 1
            SpawnCount 1
            WaitBeforeStarting 12.5
            WaitBetweenSpawns 0
            TotalCurrency 100

            TFBot
            {
                Template T_TFBot_URL_Field_General
                Action Mobber
            }

            FirstSpawnOutput
            {
                Target BigNet
                Action RunScriptCode
                Param "
                        MusicSystemMent.SetMusicTrack(`#mentrillum/mvm/music/bossrush/mini_boss_rush_2.wav`);
                      "
            }
			DoneOutput
            {
                Target BigNet
                Action RunScriptCode
                Param "
                        EntFire(`pop_interface`, `$FinishWaveSpawn`, `Wave1_Support-ShovelSoldiers`)
                        EntFire(`pop_interface`, `$KillWaveSpawn`, `Wave1_Support-ShovelSoldiers`)
						EntFire(`pop_interface`, `$FinishWaveSpawn`, `Wave1_Support-ShotgunHeavies`)
                        EntFire(`pop_interface`, `$KillWaveSpawn`, `Wave1_Support-ShotgunHeavies`)
                        EntFire(`tf_gamerules`, `$FinishWaveNoUnspawnedMoney`)
                      "
            }
        }
		WaveSpawn // Support Shovel Soldiers
		{
			Name "Wave1_Support-ShovelSoldiers"
			WaitForAllSpawned "Wave1_FieldGeneral"
			Where spawnbot_support
			Support 1
			TotalCount 100
			MaxActive 3
			SpawnCount 1
			WaitBeforeStarting 17.5
			WaitBetweenSpawns 3
			TotalCurrency 100

			TFBot
			{
				Name "Shovel Soldier"
				Class Soldier
				ClassIcon soldier_shovel
				Skill Hard
				WeaponRestrictions MeleeOnly
                Action Mobber
			}
		}
        WaveSpawn // Support Shotgun Heavies
        {
            Name "Wave1_Support-ShotgunHeavies"
			WaitForAllSpawned "Wave1_FieldGeneral"
            Where spawnbot_support
            Support 1
            TotalCount 100
            MaxActive 2
            SpawnCount 1
            WaitBeforeStarting 20
            WaitBetweenSpawns 5
            TotalCurrency 100

            TFBot
            {
                Name "Shotgun Heavy"
                Template T_TFBot_Heavyweapons_Shotgun
                Action Mobber
            }
        }

        //// Explosive Surprise ////
		WaveSpawn
        {
            Name "Wave1_ExplosiveSurprise"
            StartDisabled 1
        }
		WaveSpawn // Boss
		{
			Name "Wave1_Boss-ExplosiveSurprise"
			WaitForAllSpawned "Wave1_ExplosiveSurprise"
            Where spawnbot_boss
            TotalCount 1
            MaxActive 1
            SpawnCount 1
            WaitBeforeStarting 12.5
            WaitBetweenSpawns 0
            TotalCurrency 100

            TFBot
            {
                Template T_TFBot_Fat_Demoman_Sandman_Chief
                Action Mobber
            }

            FirstSpawnOutput
            {
                Target BigNet
                Action RunScriptCode
                Param "
                        MusicSystemMent.SetMusicTrack(`#mentrillum/mvm/music/bossrush/mini_boss_rush_2.wav`);
                      "
            }
            DoneOutput
            {
                Target BigNet
                Action RunScriptCode
                Param "
                        EntFire(`pop_interface`, `$FinishWaveSpawn`, `Wave1_Support-BatScouts`)
                        EntFire(`pop_interface`, `$KillWaveSpawn`, `Wave1_Support-BatScouts`)
						EntFire(`pop_interface`, `$FinishWaveSpawn`, `Wave1_Support-Pyros`)
                        EntFire(`pop_interface`, `$KillWaveSpawn`, `Wave1_Support-Pyros`)
                        EntFire(`tf_gamerules`, `$FinishWaveNoUnspawnedMoney`)
                      "
            }
		}
		WaveSpawn // Support Bat Scouts
		{
			Name "Wave1_Support-BatScouts"
			WaitForAllSpawned "Wave1_ExplosiveSurprise"
			Where spawnbot_support
            Support 1
            TotalCount 100
            MaxActive 4
            SpawnCount 1
            WaitBeforeStarting 17.5
            WaitBetweenSpawns 4
            TotalCurrency 100

            TFBot
            {
                Name "Bat Scout"
                Template T_TFBot_Scout_Melee
                ClassIcon scout_bat_nys
                Action Mobber
            }
		}
