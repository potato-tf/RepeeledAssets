                "OnTrigger" "pop_interface,ChangeBotAttributes,phase2,0,1"
            }
            
            logic_relay
            {
                "targetname" "deathanim_bigboom_relay"
                "ontrigger" "tf_gamerules,PlayVO,ambient\explosions\explode_2.wav,0,-1"
            }
          
