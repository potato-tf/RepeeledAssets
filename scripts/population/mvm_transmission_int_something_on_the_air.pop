		NyanTankTrail
		{
			NoFixup 1
			logic_timer
			{
				"targetname"    "tank_color_timer"
				"RefireTime"    "0.05"            
				"spawnflags"    "0"
				"StartDisabled" "0"
				"UseRandomTime" "0"
				"OnTimer"       "tank_color_state,GetValue,,0,-1"
			}
			math_counter
			{
				"targetname" "tank_color_state"
				"startvalue" "1"
				"min"        "1"
				"max"        "3" 
				"OnGetValue" "tank_color_changecase,InValue,,0,-1"
			}
			logic_case
			{
