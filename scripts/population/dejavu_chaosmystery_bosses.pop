            {
                "targetname" "beam_launcher"
                "origin" "0 0 60"
                "angles" "-40 0 0"
                "teamnum" "3"
                "$weaponnosound" "1"
                "$weaponname" "conduit_indicator_launcher"
                "$preventshootparent" "1"
                "$OnFire" "BeamSpamer,ForceSpawnAtEntityOrigin,!activator,0,-1"
