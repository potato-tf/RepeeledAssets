                "targetname" "phase2transition"
                "OnTrigger" "tf_gamerules,PlayVO,vo\mvm\mght\heavy_mvm_m_negativevocalization02.mp3,0.17,1"
                "OnTrigger" "tf_gamerules,PlayVO,vo\mvm\mght\heavy_mvm_m_battlecry03.mp3,2.5,1"
                "OnTrigger" "tf_gamerules,PlayVO,vo\mvm\mght\heavy_mvm_m_negativevocalization02.mp3,0.17,1"
