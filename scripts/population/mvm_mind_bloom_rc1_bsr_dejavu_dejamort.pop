            Where spawnbot_boss
            TotalCount 2
            MaxActive 2
            SpawnCount 2
            WaitBeforeStarting 12.5
            WaitBetweenSpawns 0
            TotalCurrency 50

            FirstSpawnWarningSound "vo\mvm\mght\heavy_mvm_m_painsharp04.mp3"

            Squad
            {
                NoWaitForFormation 1  
                NoFormation 1  
                TFBot
                { 
                    Template T_TFBot_Contact_W4Pair_Heavy_Gunner
                    FireInput
                    {
                        Target !self
                        Action $TeleportToEntity
                        Param spawnbot_target_rancher1
