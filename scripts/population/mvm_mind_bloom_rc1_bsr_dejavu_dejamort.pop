                Target "wave3stupidness"
                Action ForceSpawn
            }
            DoneOutput
            {
                Target BigNet
                Action RunScriptCode
                Param "
                        EntFire(`pop_interface`, `$KillWaveSpawn`, `Wave6_Support-BlackBoxes`)
                        EntFire(`pop_interface`, `$PauseWaveSpawn`, `Wave6_Support-BlackBoxes`)
						EntFire(`tf_gamerules`, `PlayVO`, `boss_incoming.wav`, 2.4)
