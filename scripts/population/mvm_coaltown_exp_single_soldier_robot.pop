#base robot_standard.pop
#base robot_giant.pop

//ideas for changing the mission:
//w2 - add conch to hydrogen (idk why it wasn't here) and shorten the major crits segment
//w4 - change the text to tposing soldiers spawning in and spamming voicelines, goes into whippers faster
//w6 - 3 player moment i think


WaveSchedule
{
	StartingCurrency 400
	RespawnWaveTime  0
	CanBotsAttackWhileInSpawnRoom no

	TextPrintTime 0
	MaxSpeedLimit 1200
	NoRomevisionCosmetics 1
	BodyPartScaleSpeed 5
	WaveStartCountdown 3
	AllowBotExtraSlots 1
	RobotLimit 50

    DisableSound "Announcer.MVM_Wave_End"
	DisableSound "Announcer.MVM_Bonus"
    DisableSound "music.mvm_end_wave"
    DisableSound "music.mvm_end_mid_wave"
	DisableSound "Announcer.MVM_Tank_Alert_Spawn"
