                "OnTrigger" "pickone,PickRandom,,0.5,-1"
                "OnTrigger" "pickone,PickRandom,,1.5,-1"
                "OnTrigger" "pickone,PickRandom,,2.5,-1"
                "OnTrigger" "spawner_origin,kill,,3,-1"
            }
            logic_case
            {
                "targetname" "pickone"
                "OnCase01" "MegaBeamSetup,ForceSpawnAtEntityOrigin,rotator_spawner1,0,-1"
                "OnCase02" "MegaBeamSetup,ForceSpawnAtEntityOrigin,rotator_spawner2,0,-1"
