#base robot_standard.pop
#base robot_giant.pop
#base decay_ducks.pop

// Bump in the Night - Decay Intermediate
// Made by PDA Expert as an April Fools mission.
// Centered around one gimmick only, likely going to be short.

// Wave Structure :
// W1 : Simple introduction
// W2 : Giants are added to the mix
// W3 : Tank is introduced
// W4 : Mostly a test of everything prior
// W5 : A boss fight

WaveSchedule
{
	StartingCurrency 0
	RespawnWaveTime	1
	CanBotsAttackWhileInSpawnRoom No

