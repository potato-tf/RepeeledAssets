        //Conduit Logic
        conduit_logic
        {
            game_text
            {
                "origin" "1984 1984 99999"
                "message" "Clockwork of the Iron Menace"
                "targetname" "upper_text2"
                "x" "-1"
                "y" "0.4"
                "spawnflags" "1"
                "effect" "2"
                "channel" "2"
                "color" "255 150 0"
                "fxtime" "0.2"
                "fadeout" "1"
                "holdtime" "4.8"
            }
            game_text
            {
                "origin" "1984 1984 99999"
                "message" "Colonel Conduit"
                "targetname" "lower_text1"
                "x" "-1"
                "y" "0.45"
                "spawnflags" "1"
                "channel" "1"
                "effect" "2"
                "color" "255 255 0"
                "fadein" "0.2"
                "fadeout" "1"
                "holdtime" "4.8"
            }
            OnSpawnOutput
            {
                Target boss_spawns
                Action Trigger
            }
            info_target
            {
                "targetname" "boss_thing"
                "origin" "0 0 0.3"
            }
            OnSpawnOutput
            {
                Target boss_thing
                Action SetParent
                Param "!activator"
                Delay 0.1
            }
            OnSpawnOutput
            {
                Target beam_launcher
                Action SetOwner
                Param !activator
            }
            OnSpawnOutput
            {
                Target firebomb_launcher
                Action SetOwner
                Param !activator
