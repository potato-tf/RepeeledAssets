                "OnTrigger" "StraightBeamSetup,ForceSpawnAtEntityOrigin,rotator_spawner4,0.5,-1"
                "OnTrigger" "StraightBeamSetup,ForceSpawnAtEntityOrigin,rotator_spawner1,1.6,-1"
                "OnTrigger" "StraightBeamSetup,ForceSpawnAtEntityOrigin,rotator_spawner2,1.6,-1"
                "OnTrigger" "StraightBeamSetup,ForceSpawnAtEntityOrigin,rotator_spawner3,1.6,-1"
                "OnTrigger" "StraightBeamSetup,ForceSpawnAtEntityOrigin,rotator_spawner4,1.6,-1"
                "OnTrigger" "!activator,$PlaySequence,melee_run,2.3,-1"
                "OnTrigger" "boss_sparky,TurnOff,,2.6,-1"
                "OnTrigger" "super_release,Start,,2.5,-1"
                "OnTrigger" "super_release,Stop,,2.6,-1"
                "OnTrigger" "move_relay,Trigger,,2.6,-1"
                "OnTrigger" "!activator,$AddPlayerAttribute,increased jump height|1,2.5,-1"
                "OnTrigger" "!activator,$AddPlayerAttribute,no_jump|0,2.5,-1"
                "OnTrigger" "!activator,$AddPlayerAttribute,no_attack|0,2.5,-1"
                "OnTrigger" "!activator,$AddPlayerAttribute,move speed bonus|0.7,2.5,-1"
                "OnTrigger" "spawner_origin,kill,,2.5,-1"
            }
            logic_relay
            {
                "targetname" "spam_attack_relay"
                "OnTrigger" "!activator,$BotCommand,interrupt_action -posent Enemy -lookposent RandomEnemy -duration 0.7,0,-1"
                "OnTrigger" "!activator,$AddPlayerAttribute,gesture speed increase|2,0,-1"
                "OnTrigger" "!activator,$TauntFromItem,Replay Taunt,0.7,-1"
                "OnTrigger" "beam_launcher,FireMultiple,8,1,-1"
                "OnTrigger" "!activator,$AddPLayerAttribute,gesture speed increase|1,2,-1"
            }
            logic_relay
            {
                "targetname" "laserattack"
                "OnTrigger" "RotatorSpawners,ForceSpawnAtEntityOrigin,boss_thing,0,-1"
