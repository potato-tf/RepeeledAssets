		TutuLauncherLogic	// rotating sword demo logic from midnight patrol, slightly modified with permission
		{
			func_rotating
			{
				targetname "rot"
				spawnflags 593
				fanfriction 333333
				maxspeed 400
			}
			OnSpawnOutput
			{
				target "rot"
				action "addoutput"
				param "avelocity 0 400 0"
				delay 0.01
			}
			OnSpawnOutput
			{
				target "!activator"
				action "addoutput"
				param "rendermode 10"
				delay 0.01
			}
			prop_dynamic
			{
				targetname "blade1"
				parentname "rot"
				model "models/player/items/heavy/heavy_fairy_tutu.mdl"
				skin 1
				DisableBoneFollowers 1
				// angles "0 0 -90"
			}
		}
