		WaveSpawn // Freeze the Tank's health at 40,000,000
		{
            WaitForAllSpawned	Titan
			WaitBeforeStarting	1
			FirstSpawnOutput
			{
				Target	TitanTank
                Action	RunScriptCode
                Param	"
                local scope = self.GetScriptScope().FreezeTankHealth <- function() {
                NetProps.SetPropInt(self, `m_takedamage`, 1)
                }
                self.ConnectOutput(`OnHealthBelow80Percent`, `FreezeTankHealth`)"
			}
		}
