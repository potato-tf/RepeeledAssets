			ClassIcon soldier_major_crits
			Health 60000
			Scale 1.9
			Attributes MiniBoss
			Attributes UseBossHealthBar
			Attributes HoldFireUntilFullReload
			Attributes AlwaysCrit
			Attributes SuppressFire

			UseHumanAnimations 1

			Action FollowPath   // Action that follows path specified by path keyvalue
			Path   // A path to use, for action FollowPath. Path needs either one or multiple Node keys or Track key with a name of a path_track entity. A path made of Node keys loops after completion
			{
				Node
				{
					Target "60 2459 260" // Node position or entity
					Wait 999

					Output // Fire output after approaching this node
					{
						Target !activator
						Action $TauntFromItem
						Param "Taunt: Can It!"
						Delay 0.3
					}
				}
			}

			ChangeAttributes
			{
				Delay 7
				Name "stop"
			}

			ItemAttributes
			{
				ItemName "TF_WEAPON_ROCKETLAUNCHER"
				"clip size upgrade atomic" 26.0
				"faster reload rate" 0.4
				"fire rate bonus" 0.2
				"projectile spread angle penalty" 5
				"Projectile speed increased" 0.4
			}
			CharacterAttributes
			{
				"health regen"	250
				"move speed bonus"	0.75
				"damage bonus" 1.5
				"damage force reduction" 0.4
				"airblast vulnerability multiplier" 0.4
				"override footstep sound set" 3
				"airblast vertical vulnerability multiplier" 0.1
				"rage giving scale" 0.1
				"dmg taken increased" 0.1
			}

			ChangeAttributes
			{
				stop
				{
