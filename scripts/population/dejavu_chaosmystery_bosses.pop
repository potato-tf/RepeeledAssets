            OnSpawnOutput
            {
                Target spam_origin
                Action "$setKey$angles"
                Param "180 0 0"
                Delay 0
            }
            trigger_hurt
            {
                "targetname" "spam_damage"
                "parentname" "spam_indicator"
                "mins" "-50 -50 -80"
                "maxs" "50 50 80"
                "damage" "350"
                "damagetype" "2"
                "filtername" "filter_redteam_nouber"
                "StartDisabled" "1"
