	Wave // Wave 1 - $784 ($2900 if A+)
	{
		StartWaveOutput
        {
            Target wave_start_relay
            Action Trigger
        }

        DoneOutput
        {
            Target wave_finished_relay
            Action RunScriptCode
			Param
			"
				self.AcceptInput(`Trigger`, ``, null, null)
				SendGlobalGameEvent(`teamplay_broadcast_audio`,
				{
					sound = `overwatch_main_menu1.wav`
					additional_flags = 0x4 // SND_STOP
					team = 255
				})
			"
        }

		WaveSpawn
		{
			Name "1a tracer"

			Where spawnbot
			TotalCount 20
			TotalCurrency 50
			MaxActive 5
			SpawnCount 1
			WaitBeforeStarting 0
			WaitBetweenSpawns 1
			FirstSpawnWarningSound  "overwatch_main_menu1.wav"

			TFBot
			{
				Template T_TFBot_Tracer
			}
		}

		WaveSpawn
		{
			Name "1a"

