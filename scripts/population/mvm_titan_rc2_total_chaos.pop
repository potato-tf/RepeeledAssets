		WaveSpawn													// Teleport Soldier to hatch to manipulate behavior
        {
            WaitForAllSpawned	EscortSupports1
            FirstSpawnOutput
            {
                Target bignet
                Action RunScriptCode
                Param "
                foreach( robot in m_aRobots)
                {
                    if(robot.GetTeam() != TF_TEAM_PVE_DEFENDERS)
                    continue
                    robot.SetAbsOrigin(Vector(1300, 0, 280))
                }
                "
				Delay 0.5
            }
        }
		WaveSpawn													// Teleport Heavy to hatch to manipulate behavior
        {
            WaitForAllSpawned	EscortSupports2
            FirstSpawnOutput
            {
                Target bignet
                Action RunScriptCode
                Param "
                foreach( robot in m_aRobots)
                {
                    if(robot.GetTeam() != TF_TEAM_PVE_DEFENDERS || robot.GetPlayerClass() != TF_CLASS_HEAVYWEAPONS)
                    continue
                    robot.SetAbsOrigin(Vector(1300, 0, 280))
                }
                "
				Delay 0.5
            }
        }
		WaveSpawn													// Teleport Soldier to teleporter and announce entry
        {
            WaitForAllSpawned	Escort2
            FirstSpawnOutput
            {
                Target bignet
                Action RunScriptCode
                Param "
                foreach( robot in m_aRobots)
                {
                    if(robot.GetTeam() != TF_TEAM_PVE_DEFENDERS)
                    continue
                    robot.SetAbsOrigin(Vector(-6288, -591, -25))
					robot.AddCondEx(TF_COND_TELEPORTED, 10, null)
                }
                "
            }
			DoneOutput
            {
                Target bignet
                Action RunScriptCode
                Param "
                ClientPrint(null, 3 , `\x078adb91A \x0700ff44Support Soldier \x078adb91has joined the fight!`)
                "
            }
        }
		WaveSpawn													// Teleport Heavy to teleporter and announce entry
        {
