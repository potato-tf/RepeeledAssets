                        EntFire(`pop_interface`, `$ResumeWaveSpawn`, `Wave2_Support-GRUHeavies`, 5)
                      "
            }

			DoneOutput
            {
                Target BigNet
                Action RunScriptCode
                Param "
                        EntFire(`pop_interface`, `$KillWaveSpawn`, `Wave2_Support-Pyros`)
                        EntFire(`pop_interface`, `$PauseWaveSpawn`, `Wave2_Support-Pyros`)
                        EntFire(`pop_interface`, `$PauseWaveSpawn`, `Wave2_Support-GRUHeavies`)
                        EntFire(`pop_interface`, `$KillWaveSpawn`, `Wave2_Support-GRUHeavies`)
                        
                        EntFire(`bossrushspecialspawnlocation`, `ForceSpawnAtEntityOrigin`, `spawnbot_target_bonkplant2`, 2.5)
                        EntFire(`bossrushspecialspawnlocation`, `ForceSpawnAtEntityOrigin`, `spawnbot_target_bonkplant3`, 2.5)
						EntFire(`tf_gamerules`, `PlayVO`, `boss_incoming.wav`, 2.5)
                      "
            }
		}

		WaveSpawn // Support Pyros
        {
            Name "Wave2_Support-Pyros"
            WaitForAllSpawned "Wave2_Boss2-TON618BlackHolePyro"
            Where spawnbot_support
            Support 1
            TotalCount 50
            MaxActive 3
            SpawnCount 1
            WaitBeforeStarting 5
            WaitBetweenSpawns 5
            TotalCurrency 50

            TFBot
            {
                Class Pyro
                Skill Easy
                Action Mobber
