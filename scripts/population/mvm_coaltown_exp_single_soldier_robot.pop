		HealthbarPT
		{
			NoFixup 1
			info_target
			{
				"targetname" "health_target"
				"origin" "0 0 0"
			}

			OnSpawnOutput
            {
                Target health_target
				Action SetParent
				Param "!activator"
				Delay 0.05
            }
			OnSpawnOutput
            {
                Target temporary_solution
                Action $SetOwner
                Param "@p@health_target"
                Delay 0.1
            }
		}

		Wave6Relays
		{
			NoFixup 1

			logic_relay
