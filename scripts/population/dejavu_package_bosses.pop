        T_TFBot_MainBoss_NemesisMimicry_Package
		{
			Name "Nemesis Program MK2 Mimicry"
			Tag bot_rangescript
			Class Soldier
			Skill Expert
			ClassIcon tf2_lite_shadeless
			Health 60000
			Scale 1.75
			Attributes MiniBoss
			Attributes UseBossHealthBar
			ExtAttr IgnoreBuildings
			UseMeleeThreatPrioritization 1

			CharacterAttributes
			{
				"displace touched enemies" 1
			}

			EventChangeAttributes
			{
			    // phase 1
				LongRange_FOS [$SIGSEGV]
				{
					WeaponRestrictions MeleeOnly
					Skill Expert
			    	CharacterAttributes
					{
						"override footstep sound set" 2

						"move speed bonus"	0.4
						"dmg taken increased" 0.25
						"deploy time decreased" 0.01
						"damage force reduction" 0.01
						"airblast vulnerability multiplier" 0.01
						"airblast vertical vulnerability multiplier" 0.1
						"health from healers reduced" 2
						"cancel falling damage" 1
						"Health regen" 150
						"displace touched enemies" 1
                    }
