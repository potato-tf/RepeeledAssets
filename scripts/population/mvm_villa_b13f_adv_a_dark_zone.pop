		textualtimer_v3
		{
			OnSpawnOutput
			{
				Target bignet
				Action RunScriptCode
				Param "
				IncludeScript(`textualtimer_v3`, getroottable())
				TextualTimer.SetParams({
					minutes = 1
					seconds = 40
					x = 0.33
					y = 0.77
					color = `0 255 255`
					relayname = `final_event_spawn`
					automatic = false
				})
				TextualTimer.AddCallbacks({
					
					`63` : function()
					{
						EntFire(`spawnbot_altmode`, `Enable`, ``)
					}
					`3` : function()
					{
						EntFire(`gamerules`, `PlayVO`, `missionfolderthatappearswhenyouhavetakentoolonginaghosthouse/snd_three.mp3`)
					}
					`2` : function()
					{
						EntFire(`gamerules`, `PlayVO`, `missionfolderthatappearswhenyouhavetakentoolonginaghosthouse/snd_two.mp3`)
					}
					`1` : function()
					{
						EntFire(`gamerules`, `PlayVO`, `missionfolderthatappearswhenyouhavetakentoolonginaghosthouse/snd_one.mp3`)
					}
				})
				"
			}
		}
