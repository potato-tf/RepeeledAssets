#base robot_giant.pop
#base robot_standard.pop
#base chaos_robot_special.pop
#base chaos_weapons.pop
#base chaos_players_default.pop

// -- SPAWN LOCATIONS --
// spawnbot - Anywhere from the front (Includes _mission_sniper and _mission_spy)
// spawnbot_left - Front, specifically from the left side (If you want a slightly faster entry)
// spawnbot_carrier - Front, specifically from the carrier
// spawnbot_boss - Front, specifically from behind the rocks
// spawnbot_tank - From tank entry
// spawnbot_flank - Initially spawns from cave, but will automatically teleport to mid point if reached by bomb carrier
// spawnbot_specialflank_cliff - Any "spawnbot_flank" will automatically start here for either cliffside route if the mid point was reached by bomb carrier
// spawnbot_specialflank_spiral - Any "spawnbot_flank" will automatically start here for the left route if the mid point was reached by bomb carrier
// spawnbot_utility - Isolated area for misc wave functions, can also clear at any time by sending an Enable output to "utility_kill" entity
// spawnbot_utility2 - Isolated area, instakills the bot on spawn (Primarily used for faking custom tank icons for ESCORT but may serve other niche purposes)
// spawnbot_superboss - See "ARENA"


// -- TANK PATHS --
// StartingPathTrackNode	"tank_path_left" (+4s)
// StartingPathTrackNode	"tank_path_right_down" (Fastest)
// StartingPathTrackNode	"tank_path_right_cliff" (Slowest, +26s)
// StartingPathTrackNode	"tank_path_titan" (Special path that will enlarge the tank to 2.5x size, busting through wall directly to fort)
// StartingPathTrackNode	"tank_path_red" (See "ESCORT WAVE")


// -- ENTITIES --
// wave_start_relay
// wave_finished_relay
// wave_start_relay_escort - Player spawn is relocated to a small room along the left path and the "Triple Banner" powerup becomes available.
// wave_finished_relay_next_escort - Same as regular finish, but will not choose a new path and will display red tank path holograms (Used prior to Escort wave)
// wave_finished_relay_nopath - Same as regular finish, but will not choose a new path and will not display holograms. (Used prior to Arena wave)
// turrets_activate_relay - Allows the 4 pre-built sentry guns at the fort to deploy when enemies are in range. Send a "Disable" output each wave if you don't want to use these.
// utility_kill - Send an "Enable" output to kill any bots in the spawnbot_utility area, then Disable if you intend to reuse.


// -- ESCORT WAVE --
// Players must help RED tanks reach the front lines to win
// Use DoneOutput "wave_finished_relay_next_escort" on the wave prior to this one. (This will display red tank path holograms)
// Use StartWaveOutput "wave_start_relay_escort"
//
// Have a single bot spawn with the bomb at spawnbot_utility
// Have all other bots spawn WITHOUT IgnoreFlag or any BehaviorModifier
// This will manipulate the behavior of all other bots to simply attack RED.
// They will not be concerned with assisting the bomb carrier due to how far away it is.
//
// Use "tank_path_red" as the StartingPathTrackNode for the tanks to escort.
// These tanks will automatically recolor to red and assign to red team such that bots will attack them.
// They require OnKillOutput to trigger "boss_deploy_relay" in order to set a fail condition.
// OnBombDroppedOutput will not fire as they will despawn once they successfully reach their exit, thus may be ignored.


// -- ARENA --
// Ideally used as final wave
// Send players to arena to fight a large boss
//
// Send a Trigger output to arena_battle_relay when starting the wave.
// Spawn a bot at spawnbot_utility with IgnoreFlag and give it a name.
// Once all players enter the portal to the arena this bot will automatically be killed.
// Have another bot wait 2 seconds then spawn at the same location without IgnoreFlag.
// Have the intended fight start after the first bot is done and the 2nd one has spawned with the flag.
// Use spawnbot_superboss to send all enemies to arena

population
{
	StartingCurrency	0
	RespawnWaveTime	1
	CanBotsAttackWhileInSpawnRoom	no
	FixedRespawnWaveTime	Yes
    FlagCarrierMovementPenalty 0.75
	MaxSpeedLimit 1560
	MaxEntitySpeed 50000
	NoMvMDeathTune 1
	RobotLimit 40
	BurnTimeFasterBurn 0
	MaxRedPlayers 8
