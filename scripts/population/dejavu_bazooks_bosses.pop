        //// CAPTAIN PUNCH THE MDXXVIII ////
        CaptainPunchMDXXVIII_logic
        {
            NoFixup 1
            math_counter 
			{
			"targetname" "CaptainPunchMDXXVIII_health_to_add"

			"startvalue" "0"

			"OutValue" "CaptainPunchMDXXVIII_health_updater,SetValueNoFire,0,0,-1"
			"OutValue" "!activator,$GetKey$health,CaptainPunchMDXXVIII_health_updater|Add|0,0,-1"
			"OutValue" "CaptainPunchMDXXVIII_health_updater,Add,,0,-1"
			}

			math_counter 
			{
			"targetname" "CaptainPunchMDXXVIII_health_updater"

			"startvalue" "0"

			"OutValue" "!activator,$SetKey$health,,0,-1"
			"OutValue" "CaptainPunchMDXXVIII_health_updater,SetValueNoFire,0,0,-1"
			}

			logic_relay 
			{
			"targetname" "CaptainPunchMDXXVIII_AddHealth"

			"$OnUser5" "CaptainPunchMDXXVIII_health_to_add,SetValue,,0,-1"
			}
			filter_damage_type
            {
                "damagetype" "262144"
                "Negated" "0"
                "targetname" "CaptainPunchMDXXVIII_filter_damagehealbusters"
            }
            filter_damage_type
            {
                "damagetype" "262144"
                "Negated" "1"
                "targetname" "CaptainPunchMDXXVIII_filter_nodmgfilter"
            }
            filter_tf_condition
            {
                "condition" "5"
                "Negated" "1"
                "targetname" "CaptainPunchMDXXVIII_invulnfilter"
            }
            filter_tf_condition
            {
                "condition" "52"
                "Negated" "1"
                "targetname" "CaptainPunchMDXXVIII_ubercanteenfilter"
            }
            filter_multi
            {
                "Filter01" "filter_redteam"
                "Filter02" "CaptainPunchMDXXVIII_invulnfilter"
                "Filter03" "CaptainPunchMDXXVIII_ubercanteenfilter"
                "filtertype" "0"
                "Negated" "0"
                "targetname" "CaptainPunchMDXXVIII_filter_red_notubered"
            }
            filter_tf_bot_has_tag
            {
                "Negated" "0"
                "require_all_tags" "1"
                "tags" "bossminion"
                "targetname" "CaptainPunchMDXXVIII_filter_minions"
            }
            filter_damage_type
            {
                "damagetype" "16"
                "Negated" "0"
                "targetname" "CaptainPunchMDXXVIII_filter_damagedeath"
            }
            filter_tf_bot_has_tag
            {
                "Negated" "1"
                "require_all_tags" "1"
                "tags" "AnimDeathBossTag"
                "targetname" "CaptainPunchMDXXVIII_filter_notdeathanim"
            }
            filter_tf_bot_has_tag
            {
                "Negated" "0"
                "require_all_tags" "1"
                "tags" "AnimDeathBossTag"
                "targetname" "CaptainPunchMDXXVIII_filter_isdeathanim"
            }
            filter_multi
            {
                "Filter01" "filter_blueteam"
                "Filter02" "CaptainPunchMDXXVIII_filter_notdeathanim"
                "filtertype" "0"
                "Negated" "0"
                "targetname" "CaptainPunchMDXXVIII_filter_notdeath_notred"
            }
            trigger_stun
            {
                "stun_duration" "9.5"
                "stun_type" "1"
                "stun_effects" "0"
                "filtername" "CaptainPunchMDXXVIII_filter_notdeath_notred"
                "origin" "0 0 0"
                "spawnflags" "1"
