WaveSchedule
{
    PrecacheModel "models/props_mvm/indicator/indicator_circle.mdl"
	PrecacheModel "models/bots/pyro_boss/bot_pyro_boss_gibby.mdl"
	PrecacheGeneric "materials/hud/leaderboard_class_pyro_flare_rain_homing_nys.vmt"
	PrecacheGeneric "materials/hud/leaderboard_class_pyro_flare_rain_homing_nys.vtf"
	PrecacheGeneric "materials/hud/leaderboard_class_pyro_dragon_fury_swordstone_spammer.vmt"
	PrecacheGeneric "materials/hud/leaderboard_class_pyro_dragon_fury_swordstone_spammer.vtf"
	PrecacheGeneric "materials/hud/leaderboard_class_heavy_shotgun_burst_lite.vmt"
	PrecacheGeneric "materials/hud/leaderboard_class_heavy_shotgun_burst_lite.vtf"
	PrecacheGeneric "materials/hud/leaderboard_class_spell_meteor_swordstonehel.vmt"
	PrecacheGeneric "materials/hud/leaderboard_class_spell_meteor_swordstonehel.vtf"
	PrecacheGeneric "materials/hud/leaderboard_class_pyro_dragon_fury_swordstone.vmt"
	PrecacheGeneric "materials/hud/leaderboard_class_pyro_dragon_fury_swordstone.vtf"

    PrecacheGeneric "materials/hud/leaderboard_class_engineer_pomson_v2.vmt"
    PrecacheGeneric "materials/hud/leaderboard_class_engineer_pomson_v2.vtf"
    PrecacheGeneric "materials/hud/leaderboard_class_engineer_widowmaker_inf_nys.vmt"
    PrecacheGeneric "materials/hud/leaderboard_class_engineer_widowmaker_inf_nys.vtf"
    PrecacheGeneric "materials/hud/leaderboard_class_engineer_frontier_justice_nys.vmt"
    PrecacheGeneric "materials/hud/leaderboard_class_engineer_frontier_justice_nys.vtf"
    PrecacheGeneric "materials/hud/leaderboard_class_engineer_ranger_nys_penetrate_giant.vmt"
    PrecacheGeneric "materials/hud/leaderboard_class_engineer_ranger_nys_penetrate_giant.vtf"
    PrecacheGeneric "materials/hud/leaderboard_class_soldier_rocketrain_homing_nys.vmt"
    PrecacheGeneric "materials/hud/leaderboard_class_soldier_rocketrain_homing_nys.vtf"
    PrecacheGeneric "materials/hud/leaderboard_class_soldier_mangler_v2.vmt"
    PrecacheGeneric "materials/hud/leaderboard_class_soldier_mangler_v2.vtf"
    PrecacheGeneric "materials/hud/leaderboard_class_heavy_shotgun_accurate_lite.vmt"
    PrecacheGeneric "materials/hud/leaderboard_class_heavy_shotgun_accurate_lite.vtf"


    PointTemplates
    {
        //// CHAOS SURGE ////
        //Boss Death Animation
        boss_surge_dead
		{
			OnSpawnOutput
			{
				Target "scosmetic"
				Action "TurnOff"
			}
			OnSpawnOutput
			{
				Target "chief_csurge_dead"
				Action SetPlayBackRate
				Param "0"
			}
			OnParentKilledOutput
			{
				Target "scosmetic"
				Action "TurnOn"
			}
			OnParentKilledOutput
			{
				Target chief_csurge_dead
				Action "Enable"
			}
			OnParentKilledOutput
			{
				Target csurge_is_dead
				Action Trigger
				Delay 0.1
			}
			prop_dynamic_ornament
			{
				"targetname" "scosmetic"
				"model" "models/workshop/player/items/pyro/dec24_hot_spaniel/dec24_hot_spaniel.mdl"
				"solid" "0"
				"disablebonefollowers" "1"
				"disableshadows" "1"
				"skin" "1"
				"initialowner" "chief_csurge_dead"
			}
			prop_dynamic
			{
				"targetname" "chief_csurge_dead"
				"model" "models/bots/pyro_boss/bot_pyro_boss_gibby.mdl"
				"modelscale" "1.6"
				"origin" "0 0 0"
				"angles" "0 0 0"
				"defaultanim" "taunt_unleashed_rage_pyro"
				"skin" "1"
				"startdisabled" "1"
			}
			KeepAlive 1
			logic_relay
			{
				"targetname" "csurge_is_dead"
				"OnTrigger" "chief_csurge_dead,SetPlayBackRate,1,0.1,-1"
				"OnTrigger" "chief_csurge_dead,SetAnimation,taunt_zoomin_broom_exit,3,-1"
				"OnTrigger" "ttsfx,playsound,,3.8,-1"
				"OnTrigger" "ttsfx,stopsound,,4.,-1"
				"OnTrigger" "ttdust*,start,,3.8,-1"
				"OnTrigger" "ttdust*,stop,,4,-1"
				"OnTrigger" "chaos_shake,StartShake,3.8,-1"
				"OnTrigger" "chief_csurge_dead,SetAnimation,taunt_zoomin_broom_exit,4,-1"
				"OnTrigger" "ttsfx,playsound,,4.8,-1"
				"OnTrigger" "ttsfx,stopsound,,5,-1"
				"OnTrigger" "ttdust*,start,,4.8,-1"
				"OnTrigger" "ttdust*,stop,,5,-1"
				"OnTrigger" "chaos_shake,StartShake,4.8,-1"
				"OnTrigger" "chief_csurge_dead,SetAnimation,taunt_zoomin_broom_exit,5,-1"
				"OnTrigger" "tf_gamerules,PlayVO,vo\mvm\mght\pyro_mvm_m_no01.mp3,0.1,-1"
				"OnTrigger" "tf_gamerules,PlayVO,vo\mvm\mght\pyro_mvm_m_no01.mp3,0.7,-1"
				"OnTrigger" "tf_gamerules,PlayVO,vo\mvm\mght\pyro_mvm_m_no01.mp3,1.4,-1"
				"OnTrigger" "tf_gamerules,PlayVO,vo\mvm\mght\pyro_mvm_m_no01.mp3,2.1,-1"
				"OnTrigger" "tf_gamerules,PlayVO,vo\mvm\mght\pyro_mvm_m_no01.mp3,2.8,-1"
				"OnTrigger" "tf_gamerules,PlayVO,vo\mvm\mght\pyro_mvm_m_paincrticialdeath01.mp3,3,-1"
				"OnTrigger" "csurge_is_dead1,start,,6,-1"
				"OnTrigger" "csurge_is_dead1,stop,,9,-1"
				"OnTrigger" "csurge_is_dead2,start,,6,-1"
				"OnTrigger" "csurge_is_dead2,stop,,9,-1"
				"OnTrigger" "chief_csurge_dead,kill,,6,-1"
				"OnTrigger" "csurge_shake,StartShake,,6,-1"
				"OnTrigger" "player,$PlaySoundToSelf,npc/turret_floor/die.wav,6,-1"
				"OnTrigger" "player,$PlaySoundToSelf,mvm\mvm_tank_end.wav,6,-1"
				"OnTrigger" "player,$PlaySoundToSelf,mvm\mvm_tank_explode.wav,6,-1"
			}
			KeepAlive 1
			info_particle_system
			{
				"targetname" "csurge_is_dead1"
				"origin" "0 0 0"
				"angles" "-90 0 0"
				"effect_name" "mvm_tank_destroy"
			}
			KeepAlive 1
			info_particle_system
			{
				"targetname" "csurge_is_dead2"
				"origin" "0 0 0"
				"angles" "-90 0 0"
				"effect_name" "rd_robot_explosion"
			}
			KeepAlive 1
			env_shake
			{
				"targetname" "csurge_shake"
				"spawnflag" "1"
				"amplitude" "16"
				"frequency" "9"
				"duration" "3"
			}
			KeepAlive 1
			info_particle_system
			{
				"targetname" "ttdust"
				"origin" "0 0 0"
				"effect_name" "hammer_impact_button"
			}
			KeepAlive 1
			info_particle_system
			{
				"targetname" "ttdust"
				"origin" "0 0 0"
				"effect_name" "hammer_impact_button_dust2"
			}
			KeepAlive 1
			ambient_generic
			{
				"targetname" "ttsfx"
				"message" "ambient\explosions\explode_4.wav"
				"health" "10"
				"pitch" "100"
				"radius" "6000"
				"spawnflags" "32"
				"origin" "0 0 100"
			}
			KeepAlive 1
			ambient_generic
			{
				"targetname" "ttsfx"
				"message" "ambient\explosions\explode_4.wav"
				"health" "10"
				"pitch" "100"
				"radius" "6000"
				"spawnflags" "32"
				"origin" "0 0 100"
			}
			KeepAlive 1
			env_shake
			{
				"targetname" "chaos_shake"
				"spawnflags" "4"
				"amplitude" "16"
				"radius" "1000"
				"frequency" "12"
			}
		}
        //Info Target for FlameSummon
        flame_indicator
		{
			RemoveIfKilled "markerlocation"
			KeepAlive 1
			OnParentKilledOutput
			{
				Target chaos_flame
				Action ForceSpawnAtEntityOrigin
				Param "markerlocation"
			}
			OnParentKilledOutput
			{
				Target markerlocation
				Action Kill
				Delay 0.1
			}
			info_target
			{
				"targetname" "markerlocation"
			}
		}
        //Info Target for Hell Rain
        rain_indicator
		{
			RemoveIfKilled "markerlocation"
			KeepAlive 1
			OnParentKilledOutput
			{
				Target chaos_rain
				Action ForceSpawnAtEntityOrigin
				Param "markerlocation"
			}
			OnParentKilledOutput
			{
				Target markerlocation
				Action Kill
				Delay 0.1
			}
			info_target
			{
				"targetname" "markerlocation"
			}
		}
        //Flame Summon Attack
        chaos_flame
		{
			NoFixUP 1
			RemoveIfKilled "flamesorigin"
			KeepAlive 1
			info_target
			{
				"targetname" "flamesorigin"
			}
			prop_dynamic
			{
				"targetname" "indictator"
				"parentname" "flamesorigin"
				"model" "models/props_mvm/indicator/indicator_circle.mdl"
				"skin" "1"
				"defaultanim" "start"
				"origin" "0 0 0.3"
				"angles" "0 0 0"
				"solid" "0"
				"disablebonefollowers" "1"
				"disableshadows" "1"
			}
			OnSpawnOutput
			{
				Target "indictator"
				Action "$setKey$angles"
				Param "180 0 0"
			}
			trigger_hurt
			{
				"targetname" "flameattack"
				"parentname" "flamesorigin"
				"mins" "-60 -60 -60"
				"maxs" "60 60 60"
				"damagetype" "8"
				"damage" "150"
				"startdisabled" "1"
				"spawnflags" "64"
				"onhurtplayer" "!activator,$igniteplayerduration,6,0,-1"
				"$killicon" "firedeath"
				"filtername" "filter_redteam_nouber"
			}
			info_particle_system
			{
				"targetname" "flameparticle"
				"parentname" "flamesorigin"
				"effect_name" "lava_fireball_01"
				"startdisabled" "1"
			}
			logic_relay
			{
				"targetname" "flame_relay"
				"OnTrigger" "flameparticle,start,,0,-1"
				"OnTrigger" "flameattack,enable,,0-1"
				"OnTrigger" "flameattack,disable,,6,-1"
				"OnTrigger" "flameparticle,stop,,6,-1"
				"OnTrigger" "flamesorigin,kill,,6.1,-1"
			}
		}
        chaos_rain
		{
			RemoveIfKilled "rain_origin"
			KeepAlive 1
			OnSpawnOutput
			{
				Target rain_relay
				Action Trigger
				Delay 1.5
			}
			OnSpawnOutput
			{
				Target "hellrain"
				Action "$setKey$angles"
				Param "90 0 0"
			}
			OnSpawnOutput
			{
				Target "indictator2"
				Action "$setKey$angles"
				Param "180 0 0"
			}
			info_target
			{
				"targetname" "rain_origin"
			}
			prop_dynamic
			{
				"targetname" "indictator2"
				"parentname" "rain_origin"
				"model" "models/props_mvm/indicator/indicator_circle.mdl"
				"skin" "1"
				"defaultanim" "start"
				"origin" "0 0 0.3"
				"angles" "0 0 0"
				"solid" "0"
				"disablebonefollowers" "1"
				"disableshadows" "1"
			}
			tf_point_weapon_mimic
			{
				"targetname" "hellrain"
				"parentname" "rain_origin"
				"origin" "0 0 800"
				"angles" "0 0 0"
				"$weaponname" "CSurge_hellfire"
				"$weaponnosound" "1"
			}
			logic_relay
			{
				"targetname" "rain_relay"
				"OnTrigger" "hellrain,FireOnce,,0,-1"
				"OnTrigger" "hellrain,FireOnce,,1.5,-1"
				"OnTrigger" "hellrain,FireOnce,,3,-1"
				"OnTrigger" "rain_origin,kill,,4.5,-1"
			}
		}
        chaos_logic
		{
			NoFixUp 1
            env_entity_maker
            {
                "targetname" "flame_spawner"
                "entitytemplate" "flame_indicator"
                "$autoparent" "1"
            }
            env_entity_maker
            {
                "targetname" "rain_spawner"
                "entitytemplate" "rain_indicator"
                "$autoparent" "1"
            }
			tf_point_weapon_mimic
			{
				"targetname" "fireballs"
				"parentname" "firerotation"
				"origin" "0 0 50"
				"angles" "0 90 0"
				"teamnum" "3"
				"$weaponnosound" "1"
				"$weaponname" "csurge_firering_launcher"
			}
			tf_point_weapon_mimic
			{
				"targetname" "fireballs"
				"parentname" "firerotation"
				"origin" "0 0 50"
				"angles" "0 -90 0"
				"teamnum" "3"
				"$weaponnosound" "1"
				"$weaponname" "csurge_firering_launcher"
			}
            tf_point_weapon_mimic
            {
                "targetname" "flame_summon_setup"
                "origin" "0 0 50"
                "angles" "-90 0 0"
                "teamnum" "3"
                "$weaponnosound" "1"
                "$weaponname" "CSurge_indicatorlauncher"
                "$preventshootparent" "1"
                "$OnFire" "flame_spawner,ForceSpawnAtEntityOrigin,!activator,0,-1"
            }


            tf_point_weapon_mimic
            {
                "targetname" "hell_rain_setup"
                "origin" "0 0 80"
                "angles" "-10 0 0"
                "teamnum" "3"
                "$weaponnosound" "1"
                "$weaponname" "CSurge_indicatorlauncher2"
                "$preventshootparent" "1"
                "$OnFire" "rain_spawner,ForceSpawnAtEntityOrigin,!activator,0,-1"
            }
			func_rotating
			{
				"targetname" "firerotation"
				"origin" "0 0 40"
				"mins" "-8 -8 -8"
				"maxs" "8 8 8"
				"fanfriction" "250"
				"maxspeed" "50"
				"rendermode" "10"
				"spawnflags" "64"
			}
			game_text
			{
				"origin" "1984 1984 99999"
				"message" "CORRUPTION OF PERSEVERANCE"
				"targetname" "upper_text1"
				"x" "-1"
				"y" "0.4"
				"spawnflags" "1"
				"effect" "2"
				"channel" "0"
				"color" "255 0 0"
				"fxtime" "0.2"
				"fadeout" "1"
				"holdtime" "4.8"
			}
			game_text
			{
				"origin" "1984 1984 99999"
				"message" "Chaos Surge"
				"targetname" "ex_text"
				"x" "-1"
				"y" "0.45"
				"spawnflags" "1"
				"channel" "1"
				"effect" "2"
				"color" "255 87 51"
				"fadein" "0.2"
				"fadeout" "1"
				"holdtime" "4.8"
			}
			OnSpawnOutput
			{
				Target "upper_text1"
				Action Display
			}
			OnSpawnOutput
			{
				Target "ex_text"
				Action Display
				Delay 1.4
			}
			OnSpawnOutput
			{
				Target "firerotation"
				Action "addoutput"
				Param "avelocity 0 200 0"
				Delay 0.01
			}
			OnSpawnOutput
			{
				Target "firerotation"
				Action "SetSpeed"
				Param "100"
				Delay 0.01
			}
			OnSpawnOutput
			{
				Target "fireballs"
				Action "$SetOwner"
				Param "!activator"
			}
			OnSpawnOutput
			{
				Target "flame_summon_setup"
				Action "$SetOwner"
				Param "!activator"
			}
			OnSpawnOutput
			{
				Target "hell_rain_setup"
				Action "$SetOwner"
				Param "!activator"
			}
			logic_timer
			{
				"targetname" "fireball_timer"
				"startdisabled" "1"
				"refiretime" "0.24"
				"OnTimer" "fireballs,FireOnce,,0,-1"
			}
			logic_relay
			{
				"targetname" "fireballs_relay"
				"OnTrigger" "!activator,$TauntFromItem,The Shred Alert,0,-1"
				"OnTrigger" "fireball_timer,enable,,0.5,-1"
				"OnTrigger" "fireball_timer,Disable,,4.5,-1"
			}
            logic_relay
            {
                "targetname" "hell_rain_relay"
                "OnTrigger" "!activator,$TauntFromItem,replay taunt,0.1,-1"
                "OnTrigger" "hell_rain_setup,FireMultiple,8,0.2,-1"
            }
			logic_case
			{
				"targetname" "surge_weapons_only"
				"OnCase01" "!activator,$ChangeAttributes,FurySpammer,0,-1"
				"OnCase02" "!activator,$ChangeAttributes,BurstShotgun,0,-1"
				"OnCase03" "!activator,$ChangeAttributes,Barrage,0,-1"
				"OnCase04" "!activator,$ChangeAttributes,HomingFlare,0,-1"
			}
			logic_case
			{
				"targetname" "surge_attacks"
				"OnCase01" "!activator,$ChangeAttributes,FurySpammer,0,-1"
				"OnCase02" "!activator,$ChangeAttributes,BurstShotgun,0,-1"
				"OnCase03" "!activator,$ChangeAttributes,Barrage,0,-1"
				"OnCase04" "!activator,$ChangeAttributes,HomingFlare,0,-1"
				"OnCase05" "!activator,$ChangeAttributes,HellRain,0,-1"
				"OnCase06" "!activator,$ChangeAttributes,FireRing,0,-1"
				"OnCase07" "!activator,$ChangeAttributes,FlameSummon,0,-1"
			}
            logic_relay
            {
                "targetname" "flame_summon_relay"
                "OnTrigger" "flame_summon_setup,FireMultiple,10,0,-1"
                "OnTrigger" "flame_relay,Trigger,,4,-1"
            }
		}

        //// COLONEL CONDUIT ////
        //Boss Death Template
        chief_conduit_dead
        {
            KeepAlive 1
            OnSpawnOutput
            {
                Target conduit_cosmetic
                Action TurnOff
            }
            OnSpawnOutput
            {
                Target conduit_dead
                Action SetPlayBackRate
                Param 0
            }
            OnParentKilledOutput
            {
                Target conduit_cosmetic
                Action TurnOn
            }
            OnParentKilledOutput
            {
                Target conduit_dead
                Action Enable
            }
            OnParentKilledOutput
            {
                Target conduit_dies
                Action Trigger
                Delay 0.1
            }
            prop_dynamic_ornament
            {
                "targetname" "conduit_cosmetic"
                "initialowner" "conduit_dead"
                "model" "models/player/items/engineer/engy_earphones.mdl"
                "solid" "0"
                "disablebonefollowers" "1"
                "disableshadows" "1"
                "skin" "1"
            }
            prop_dynamic_ornament
            {
                "targetname" "conduit_cosmetic"
                "initialowner" "conduit_dead"
                "model" "models/workshop/player/items/engineer/dec16_packable_provisions/dec16_packable_provisions.mdl"
                "solid" "0"
                "disablebonefollowers" "1"
                "disableshadows" "1"
                "skin" "1"
            }
            prop_dynamic_ornament
            {
                "targetname" "conduit_cosmetic"
                "initialowner" "conduit_dead"
                "model" "models/workshop/player/items/engineer/dec23_sleuth_suit/dec23_sleuth_suit.mdl"
                "solid" "0"
                "disablebonefollowers" "1"
                "disableshadows" "1"
                "skin" "1"
            }
            KeepAlive 1
            prop_dynamic
            {
                "targetname" "conduit_dead"
                "model" "models/bots/engineer/bot_engineer.mdl"
                "modelscale" "1.4"
                "origin" "0 0 0"
                "angles" "0 0 0"
                "defaultanim" "Primary_death_backstab"
                "skin" "1"
                "startdisabled" "1"
            }
            logic_relay
            {
                "targetname" "conduit_dies"
                "OnTrigger" "conduit_dead,SetPlayBackRate,0.5,0,-1"
                "OnTrigger" "tf_gamerules,PlayVO,vo/mvm/norm/engineer_mvm_paincriticaldeath05.mp3,0.3,-1"
                "OnTrigger" "conduit_dead,kill,,3,-1"
                "OnTrigger" "conduit_shake,StartShake,,3,-1"
                "OnTrigger" "conduit_is_dead1,start,,3,-1"
                "OnTrigger" "conduit_is_dead2,start,,3,-1"
                "OnTrigger" "conduit_is_dead1,stop,,6,-1"
                "OnTrigger" "conduit_is_dead2,stop,,6,-1"
                "OnTrigger" "player,$PlaySoundToSelf,npc/turret_floor/die.wav,3,-1"
                "OnTrigger" "player,$PlaySoundToSelf,mvm\mvm_tank_end.wav,3,-1"
                "OnTrigger" "player,$PlaySoundToSelf,mvm\mvm_tank_explode.wav,3,-1"
            }
            info_particle_system
            {
                "targetname" "conduit_is_dead1"
                "origin" "0 0 0"
                "angles" "-90 0 0"
                "effect_name" "mvm_tank_destroy"
            }
            info_particle_system
            {
                "targetname" "conduit_is_dead2"
                "origin" "0 0 0"
                "angles" "-90 0 0"
                "effect_name" "rd_robot_explosion"
            }
            env_shake
            {
                "targetname" "conduit_shake"
                "spawnflag" "1"
                "amplitude" "16"
                "frequency" "9"
                "duration" "3"
            }
        }
        //Rotator Info Targets for Two Attacks
        RotatorSpawners
        {
            NoFixUp 1
            RemoveIfKilled spawner_origin
            info_target
            {
                "targetname" "spawner_origin"
            }
            info_target
            {
                "targetname" "rotator_spawner1"
                "origin" "0 0 0.3"
                "angles" "0 -90 0"
                "parentname" "boss_rotator"
            }
            info_target
            {
                "targetname" "rotator_spawner2"
                "origin" "0 0 0.3"
                "angles" "0 90 0"
                "parentname" "boss_rotator"
            }
            info_target
            {
