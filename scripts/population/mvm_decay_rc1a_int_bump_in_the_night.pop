        T_TFBot_SentryBuster_Bumpercar
        {
            Class Demoman
            Name "Sentry Buster in a Car"
            Health 1000
            Skill Hard
            ClassIcon sentry_buster_bumper_car
            UseHumanAnimations 1

            Attributes MiniBoss
            Attributes AutoJump

            AutoJumpMin 4
            AutoJumpMax 6

            AddCond { Index 82 Delay 3 }

            WeaponRestrictions MeleeOnly

            FireWeapon
            {
                Delay 0.25
                Cooldown 2
                IfSeeTarget 1
                Duration 1
                Type "Secondary"
            }

            FireWeapon
            {
                Delay 0.25
                Cooldown 4
                IfSeeTarget 1
                Duration 1
                Type "Jump"
            }

            FireInput
            {
                Target "!self"
                Action "$RemoveCond"
                Param "82"
                Delay 1.2
                Repeats 1
                IfSeeTarget 1
            }

            FireInput // in case the buster doesn't find a victim in 20 seconds
            {
                Target "!self"
                Action "$RemoveCond"
                Param "82"
                Delay 20
                Repeats 1
                IfSeeTarget 0
            }

            Item "The Scotsman's Skullcutter"

            ItemAttributes
            {
                ItemName "The Scotsman's Skullcutter"
                "custom item model" "models/empty.mdl"
                "custom kill icon" "megaton"
            }

            Action SuicideBomber
            UseBusterModel 1

            CharacterAttributes
            {
                "move speed bonus" 2
                "increased jump height" 1.2
                "gesture speed increase" 0.825
                "voice pitch scale" 2
                "always allow taunt" 1
                "fire input on taunt" "!self^$RemoveCond^82"
            }
        }
        // 3 phase fight(?)
        // go through hoops to get the mega weapon to damage him proper.

        // attacks :
        // cannon ball barrage (default)
        // sticky rain (shoots a bunch of stickies into the air which explode shortly after, indicated by him doing the bottle sequence as the tank cannon on his back does the work with a small alarm before it starts firing.)
        // cross slam (leaps up into the air, staying for a brief moment before slamming down, shooting out rocks in a cross pattern while also doing some aoe damage. This attack is first present in phase 2 and is directly combo'd with sticky rain on phase 3)
        // non-rider spawn (spawns support, getting stronger for each phase)
        // buster call (spawns in bumper busters, exclusive to phase 2 as phase 3 will have them occasionally spawn in on their own terms)
        // banana barrage (shoots out a bunch of banana peels onto the floor, which take a bit to expire. Making contact with them will make you extra slippery while also applying a ton of knockback. This attack is replaced with Caltrops on phase 3 instead. Rocket Jumper sfx will play when he switches to this weapon.)
        // caltrops (similar to banana barrage, but more damage focused with bleed instead of slippery and actually dealing damage. Cleaver sfx will play when he switches to this weapon.)
        // caber toss (tosses a nuclear caber next to himself while doing the sequence, this is a high damaging move that'll likely also afflict afterburn. Exclusive to phase 3)
        T_TFBot_Boss_Race_Hater 
        {			

            // Base attributes
            Class Demoman
			Name "Race Hater"
			ClassIcon demo_undying
			Skill Expert
			Health 100000

			Attributes HoldFireUntilFullReload
			Attributes MiniBoss
            Attributes UseBossHealthBar
            Attributes DisableDodge
            Action Mobber
            AlwaysGlow 1
            UseHumanAnimations 1

            SpawnTemplate boss_attacks_and_stuff

            Item "The Smoking Skid Lid"
            Item "Mad Mask"
            Item "Mad Lad"
            Item "Boss Goggles"
            //Item "Boss Cannon"
            Item "The Mantreads"
            Item "Boss' Loose Cannon"

            FireInput
            {
                Target "!self"
                Action "$SetLocalOrigin"
                Param "23 -248 582"
                Delay 0
                Repeats 1
            }            
            
            FireInput
            {
                Target "!self"
                Action "$GiveItem"
                Param "Boss Cannon"
                Delay 0.25
                Repeats 1
            }

            InterruptAction // occasionally move to the middle of the map
            {
                Target "-37 275 355"
                Delay 12
                Repeats 0
                Cooldown 15
                Duration 3
            }

			Taunt
			{
				Delay 0.2
				Repeats 1
				Name "Taunt: Unleashed Rage"
			}

			CharacterAttributes
			{
				"move speed bonus"	1.1
				"damage force reduction" 0.01
                "dmg taken increased" 0.075 // reduce chip dmg
				"airblast vulnerability multiplier" 0.01
                "airblast vertical vulnerability multiplier" 0.01
				"override footstep sound set" 4
                "always allow taunt" 1
                "dmg taken mult from special damage type 1" 4 // a bit less but still should be ok
                "cancel falling damage" 1
			}

            // Phase related stuff

            FireInput
            {
                Target "ducks_respawn_nodelay_nosound"
                Action "Trigger"
                Delay 6
                Repeats 1
            }            
            
            FireInput
            {
                Target "phase1_attacks"
                Action "Trigger"
                Delay 6
                Repeats 1
            }
            
            FireInput
            {
                Target "phase1_timer"
                Action "enable"
                Delay 6
                Repeats 1
            }
            
            FireInput
            {
                Target "phase2_trigger"
                Action "trigger"
                Delay 0
                Repeats 1
                IfHealthBelow 70001
            }
            
            FireInput
            {
                Target "phase3_trigger"
                Action "trigger"
                Delay 0
                Repeats 1
                IfHealthBelow 40001
            }
        }

