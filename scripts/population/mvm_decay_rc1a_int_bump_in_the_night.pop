        boss_attacks_and_stuff
        {
            NoFixUp 1

            // documentation for fututre
            // phase 1 : cannon balls > banana barrage > sticky rain > cannon balls > sticky rain then repeats
            // phase 2 : cannon balls > cross slam > cannon balls > cannon balls > sticky rain > banana barrage > cross slam > sticky rain then repeats
            // phase 3 : starts with cross slam (p3 variant) then > cannon balls > caltrops > cross slam (p3) > caltrops > caber toss > cannon balls > caber toss > cross slam (p3) then repeats

            // Phase Handlers

            logic_relay
            {
                "targetname" "phase_switch_general"
                // disable timers
                "OnTrigger" "phase1_timer,disable,,0,-1"
                "OnTrigger" "phase2_timer,disable,,0,-1"
                // stop any future stuff coming through
                "OnTrigger" "phase1_attacks,CancelPending,,0,-1"
                "OnTrigger" "phase2_attacks,CancelPending,,0,-1"
                // stop any attacks that could possibly be happening
                "OnTrigger" "sticky_rain_attack,CancelPending,,0,-1"
                "OnTrigger" "sticky_rain_projectiles,$StopFiring,,0,-1"
                "OnTrigger" "cross_slam_attack,CancelPending,,0,-1"
                // clear ducks if they're somehow present or if they're about to spawn
                "OnTrigger" "ducks_tutorial,CancelPending,,0,-1"
                "OnTrigger" "ducks_respawn,CancelPending,,0,-1"
                "OnTrigger" "duck_collect*,kill,,0,-1"
                "OnTrigger" "duck_collect*,kill,,1,-1"
                // give him back his default weapon
                "OnTrigger" "race_hater_boss,$GiveItem,Boss' Loose Cannon,0,-1"
                "OnTrigger" "race_hater_boss,$GiveItem,Boss' Loose Cannon,1,-1" // good measure
            }

            logic_relay // unused
            {
                "targetname" "phase1_trigger"
                "ontrigger" "duck_phase_hint,show,,3,-1"
                "ontrigger" "race_hater_boss,$AddCond,52 6,0,-1"
                "ontrigger" "race_hater_boss,$AddCond,71 6,0,-1"
                "ontrigger" "phase_switch_general,Trigger,,0,-1"
                "ontrigger" "phase1_timer,Enable,,6,-1"
                "ontrigger" "phase1_attacks,Trigger,,6,-1"
                "ontrigger" "ducks_respawn_nodelay,trigger,,6,-1"
                "ontrigger" "new_populator,$ResumeWavespawn,support2,6,-1"
            }            
            
            logic_relay
            {
                "targetname" "phase2_trigger"
                "OnTrigger" "tf_gamerules,PlayVO,misc\halloween\merasmus_stun.wav,0,-1"
                "OnTrigger" "tf_gamerules,PlayVO,vo\mvm\mght\demoman_mvm_m_painsevere03.mp3,0.7,-1"
                "OnTrigger" "tf_gamerules,PlayVO,vo\mvm\mght\demoman_mvm_m_negativevocalization01.mp3,2.7,-1"
                "ontrigger" "race_hater_boss,$AddCond,52 3,0,-1"
                "ontrigger" "race_hater_boss,$AddCond,71 3,0,-1"
                "ontrigger" "phase_switch_general,Trigger,,0,-1"
                "OnTrigger" "phase1_attacks,kill,,0.1,-1"
                "OnTrigger" "phase1_timer,kill,,0.5,-1"
                "ontrigger" "phase2_timer,Enable,,3,-1"
                "ontrigger" "phase2_attacks,Trigger,,3,-1"
                "ontrigger" "ducks_respawn_nodelay,trigger,,3,-1"
                "ontrigger" "new_populator,$ResumeWavespawn,support3,3,-1"
                "OnTrigger" "kicking_ass_time_is_over,Enable,,3,-1"
                "OnTrigger" "kicking_ass_time_is_over,Disable,,3.2,-1"
                "OnTrigger" "bumpercar_mode,Enable,,3,-1"
                "OnTrigger" "bumpercar_mode_timer,Enable,,3,-1"
            }            
            
            logic_relay
            {
                "targetname" "phase3_trigger"
                "OnTrigger" "tf_gamerules,PlayVO,misc\halloween\merasmus_stun.wav,0,-1"
                "OnTrigger" "tf_gamerules,PlayVO,vo\mvm\mght\demoman_mvm_m_painsevere03.mp3,0.7,-1"
                "OnTrigger" "tf_gamerules,PlayVO,vo\mvm\mght\taunts\demoman_mvm_m_taunts11.mp3,3.7,-1"
                "ontrigger" "boss_music_loop1,kill,,0,-1"
                "ontrigger" "boss_music_loop2,kill,,0,-1"
