                    }
                    FireInput
                    {
                        Target "!self"
                        Action "RunScriptCode"
                        Param "self.AddCond(Constants.ETFCond.TF_COND_MEDIGUN_UBER_BULLET_RESIST);self.AddCond(Constants.ETFCond.TF_COND_MEDIGUN_UBER_BLAST_RESIST);self.AddCond(Constants.ETFCond.TF_COND_MEDIGUN_UBER_FIRE_RESIST);"
