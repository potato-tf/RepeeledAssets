// mvm_coastrock_rc2
// meme mission hexerfixation by Hexalina!

#base robot_giant.pop
#base robot_standard.pop

WaveSchedule
{
	StartingCurrency 2016
	RespawnWaveTime 2
	CanBotsAttackWhileInSpawnRoom no
	AddSentryBusterWhenKillCountExceeds 11
	AddSentryBusterWhenDamageDealtExceeds 1000
	Advanced 1

	// Mission

	Mission // Sentry Busters
	{
		Objective DestroySentries

		InitialCooldown 30
		Where spawnbot
		BeginAtWave 1
		RunForThisManyWaves 3
		CooldownTime 30

        TFBot
	    {
		    Template T_TFBot_SentryBuster
			Item "Potato Hat"
			Name "NO MEDALS FOR YOU"
			ItemAttributes
			{
				ItemName "Potato Hat"
				"set item tint rgb" 16738740
			}
			CharacterAttributes
			{
				"head scale" 1.3
			}
        }
	}

