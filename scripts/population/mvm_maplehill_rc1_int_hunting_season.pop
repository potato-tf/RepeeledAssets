#base robot_standard.pop
#base robot_giant.pop
#base robot_moonlight_nai.pop
#base birdy_blimp.pop

WaveSchedule
{
    StartingCurrency 800
    RespawnWaveTime 4
	FixedRespawnWaveTime No
    ForceRedMoney 1
	CanBotsAttackWhileInSpawnRoom No
    SniperAllowHeadshots 1
    BotsAreHumans  2 // Makes the Human
    NoRomevisionCosmetics	1 //All roads dont lead to Rome
    //Bird Icons//
    PrecacheGeneric "materials/hud/leaderboard_class_demo_bird"
    PrecacheGeneric "materials/hud/leaderboard_class_demo_bird_giant"
    PrecacheGeneric "materials/hud/leaderboard_class_demo_bird_random"
    PrecacheGeneric "materials/hud/leaderboard_class_engineer_bird"
