			}
			ItemAttributes
			{
				ItemName "TF_WEAPON_FISTS"
				//"damage causes airblast" 1
				"damage bonus" 2
                "is_passive_weapon" 1
			}
            CharacterAttributes
            {
                "move speed bonus" 0.9
            }
		}

