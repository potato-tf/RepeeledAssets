            {
                Target "LightningRainAttack"
                Action "ForceSpawnAtEntityOrigin"
                Param "LightningTarget"
                Delay 0.1
                Repeats 1
                Cooldown -1
            }
            OnParentKilledOutput
            {
                Target "LightningTarget"
                Action Kill
                Delay 0.5
                Repeats 1
                Cooldown -1
            }
		}
