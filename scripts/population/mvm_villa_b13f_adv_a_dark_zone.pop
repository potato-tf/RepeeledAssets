	Wave
	{
		InitWaveOutput
		{
			Target gamerules
			Action RunScriptCode
			Param "IncludeScript(`a_dark_zone.nut`, getroottable())
			EntFire(`altmode_init_reviveonly_locked_relay`,`Trigger`)
			IncludeScript(`alternatewaves.nut`, getroottable())
			IncludeScript(`buddhamode.nut`, getroottable())
			IncludeScript(`tankextensions_main`, getroottable())
			IncludeScript(`tankextensions/combattank`, getroottable())
			IncludeScript(`tankextensions/combattank_weapons/fireball`, getroottable())
			IncludeScript(`tankextensions/combattank_weapons/railgun`, getroottable())
			IncludeScript(`tankextensions/combattank_weapons/minigun`, getroottable())
			IncludeScript(`tankextensions/combattank_weapons/rocketpod`, getroottable())
			TankExt.SetValueOverrides({
				COMBATTANK_MAX_RANGE = 1200
				COMBATTANK_ROTATE_SPEED_DEFAULT = 0.666
				})"
		}
		StartWaveOutput
		{
			Target wave_start_relay
			Action Trigger
		}
		DoneOutput					
		{
			Target wave_finished_relay
			Action Trigger
		}
		Explanation 
		{
			Line "{FE7100}... GHO HO HO... IT SEAMS YOU'VE FOUND YOARSELVES IN MY [DARK ZONE]."
			Line "{FE7100}THERE'S NO ESCAIPE FROM THIS SPOOKEY PLACE..."
			Line "{FE7100}UNLESS... YOU LEAVE"
		}
		SpawnTemplate		
		{
			Name "Wave0Logic"
