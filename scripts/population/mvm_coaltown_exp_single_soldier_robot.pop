        GlobalThings
        {
            NoFixup 1
			OnSpawnOutput
			{
				Target bignet
				Action RunScriptCode
				Param "local hRelay = Entities.CreateByClassname(`logic_relay`), hGameRules = Entities.FindByClassname(null, `tf_gamerules`), iCountdownLast = -1; NetProps.SetPropBool(hRelay, `m_bForcePurgeFixedupStrings`, true); hRelay.ValidateScriptScope(); hRelay.GetScriptScope().Think <- function() { local flRestartRoundTime = NetProps.GetPropFloat(hGameRules, `m_flRestartRoundTime`); if(flRestartRoundTime != -1) { local iCountdown = ceil(flRestartRoundTime - Time()).tointeger(); if(iCountdown != iCountdownLast && iCountdown == 3) EntFire(`fuckdick_wave6_relay`, `Trigger`, null, -1, null); iCountdownLast = iCountdown } else iCountdownLast = -1; return -1 } AddThinkToEnt(hRelay, `Think`)"
			}
