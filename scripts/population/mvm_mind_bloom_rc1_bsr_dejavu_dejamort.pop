                }
            }

            FirstSpawnOutput
            {
                Target BigNet
                Action RunScriptCode
                Param "
                        EntFire(`pop_interface`, `$ResumeWaveSpawn`, `Wave2_Support-Pyros`, 5)
                        EntFire(`pop_interface`, `$ResumeWaveSpawn`, `Wave2_Support-GRUHeavies`, 5)
                      "
            }
        }
        WaveSpawn
        {
