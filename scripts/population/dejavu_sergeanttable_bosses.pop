        FallenShocksArenaLogic
        {
            // The Shocks Intro
            OnSpawnOutput
            {
                Target the_funny_man_3
                Action "TurnOff"
            }
            OnSpawnOutput
            {
                Target soldiermdl*
                Action "TurnOff"
            }
            OnSpawnOutput
            {
                Target fake_boss_flavor*
                Action "TurnOff"
            }
            OnSpawnOutput
            {
                Target ShocksItem
                Action Disable
            }

            logic_relay
            {
                "targetname" "FallenShocksIntroRelay"

                "OnTrigger" "the_funny_man_3,Enable,,0,-1"
                "OnTrigger" "soldiermdl*,Enable,,0,-1"
                "OnTrigger" "iceshield,Enable,,0,-1"
                "OnTrigger" "fake_boss_flavor*,Enable,,0,-1"
