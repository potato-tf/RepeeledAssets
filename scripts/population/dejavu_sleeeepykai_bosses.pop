        //// MAIN BOSSES ////

        T_TFBot_Mainboss_MasterMechanic_Kai
        {
            Name "The Master Mechanic"
            Class Engineer
            ClassIcon engineer_beepboy
            Skill Expert
            Health 50000
            Scale 2
            Attributes MiniBoss
            Attributes UseBossHealthBar
            Action Mobber
            WeaponRestrictions PrimaryOnly
            ExtAttr IgnoreBuildings
            UseMeleeThreatPrioritization 1

            UseHumanAnimations 1

            SpawnTemplate MasterMechanicCoreLogic
            SpawnTemplate MasterMechanicCoreEffects

            Item "Beep Man"
            Item "The Beep Boy"

            CharacterAttributes
            {
                "move speed penalty" 0.4
                "damage force reduction" 0.1
                "airblast vulnerability multiplier" 0.1
                "voice pitch scale" 0
                "override footstep sound set" 4
                "always allow taunt" 1
                "displace touched enemies" 1
            }

            // Intro Taunt
            Addcond
            {
                Index 51
                Duration 5
            }
            Taunt
            {
                Delay 0.1
                Repeats 1
                Cooldown -1
            }
            FireInput
            {
                Target tf_gamerules
                Action PlayVO
                Param vo/mvm/norm/engineer_mvm_gunslingertriplepunchfinal01.mp3
                Delay 0.1
                Repeats 1
                Cooldown -1
            }

            // Begin Attack Patterns (This will be the main relay that's called upon for initiating a phase or changing attacks in a phase)
            FireInput
            {
                Target "MasterMechanic_AttackInit"
                Action Trigger
                Delay 3.5
                Repeats 1
                Cooldown -1
            }

            // Rocket Tank
            ChangeAttributes
            {
                Name "MasterMechanic_RocketTankSummonBegin"
                Delay -1
                Repeats 1
                Cooldown -1
                IfHealthBelow 35001
            }

            // Minigun Tank
            ChangeAttributes
            {
                Name "MasterMechanic_MinigunTankSummonBegin"
                Delay -1
                Repeats 1
                Cooldown -1
                IfHealthBelow 25001
            }

            // Phase 2 Init
            FireInput
            {
                Target "MasterMechanic_Phase1AttackPoolRelay"
                Action "Disable"
                Delay -1
                Repeats 1
                Cooldown -1
                IfHealthBelow 25001
            }
            FireInput
            {
                Target "MasterMechanic_Phase2AttackPoolRelay"
                Action "Enable"
                Delay -1
                Repeats 1
                Cooldown -1
                IfHealthBelow 25001
            }

            // Railgun Tank
            ChangeAttributes
            {
                Name "MasterMechanic_RailgunTankSummonBegin"
                Delay -1
                Repeats 1
                Cooldown -1
                IfHealthBelow 15001
            }

            // Phase 3 Init
            FireInput
            {
                Target "MasterMechanic_Phase2AttackPoolRelay"
                Action "Disable"
                Delay -1
                Repeats 1
                Cooldown -1
                IfHealthBelow 15001
            }
            FireInput
            {
                Target "MasterMechanic_Phase3AttackPoolRelay"
                Action "Enable"
                Delay -1
                Repeats 1
                Cooldown -1
                IfHealthBelow 15001
            }

            EventChangeAttributes
            {
                // General EventChangeAttributes
                MasterMechanic_RocketTankSummonBegin [$SIGSEGV] // Interrupt actions to the middle of the arena while having some damage resistance
                {
                    Item "The Eureka Effect"
                    WeaponRestrictions MeleeOnly

                    CharacterAttributes
                    {
                        "move speed bonus" 2
                        "dmg from ranged reduced" 0.25
                        "dmg from melee increased" 0.25
                    }

                    InterruptAction
                    {
                        Target "-6143 -5249 -712"
                        Delay 0.5
                        Repeats 1
                        Cooldown -1
                        Distance 100
                        Duration 0.1
                        WaitUntilDone 0.1
                        OnDoneChangeAttributes "MasterMechanic_RocketTankSummonReal"
                    }
                }
                MasterMechanic_RocketTankSummonReal [$SIGSEGV]
                {
                    WeaponRestrictions MeleeOnly

                    CharacterAttributes
                    {
                        "move speed bonus" 0.001
                        "no_attack" 1
                        "no_jump" 1
                        "dmg from ranged reduced" 0.25
                        "dmg from melee increased" 0.25
                    }

                    ClientCommand
                    {
                        Name "eureka_teleport 1"
                        Delay 0.5
                        Repeats 1
                        Cooldown -1
                    }

                    FireInput
                    {
                        Target "MasterMechanic_RocketTankPhase"
                        Action "Trigger"
                        Delay 2.5
                        Repeats 1
                        Cooldown -1
                    }
                }

                MasterMechanic_MinigunTankSummonBegin [$SIGSEGV] // Interrupt actions to the middle of the arena while having some damage resistance
                {
                    Item "The Eureka Effect"
                    WeaponRestrictions MeleeOnly

                    CharacterAttributes
                    {
                        "move speed bonus" 2
                        "dmg from ranged reduced" 0.25
                        "dmg from melee increased" 0.25
                    }

                    InterruptAction
                    {
                        Target "-6143 -5249 -712"
                        Delay 0.5
                        Repeats 1
                        Cooldown -1
                        Distance 100
                        Duration 0.1
                        WaitUntilDone 0.1
                        OnDoneChangeAttributes "MasterMechanic_MinigunTankSummonReal"
                    }
                }
                MasterMechanic_MinigunTankSummonReal [$SIGSEGV]
                {
                    WeaponRestrictions MeleeOnly

                    CharacterAttributes
                    {
                        "move speed bonus" 0.001
                        "no_attack" 1
                        "no_jump" 1
                        "dmg from ranged reduced" 0.25
                        "dmg from melee increased" 0.25
                    }

                    ClientCommand
                    {
                        Name "eureka_teleport 1"
                        Delay 0.5
                        Repeats 1
                        Cooldown -1
                    }

                    FireInput
                    {
                        Target "MasterMechanic_MinigunTankPhase"
                        Action "Trigger"
                        Delay 2.5
                        Repeats 1
                        Cooldown -1
                    }
                }

                MasterMechanic_RailgunTankSummonBegin [$SIGSEGV] // Interrupt actions to the middle of the arena while having some damage resistance
                {
                    Item "The Eureka Effect"
                    WeaponRestrictions MeleeOnly

                    CharacterAttributes
                    {
                        "move speed bonus" 2
                        "dmg from ranged reduced" 0.25
                        "dmg from melee increased" 0.25
                    }

                    InterruptAction
                    {
                        Target "-6143 -5249 -712"
                        Delay 0.5
                        Repeats 1
                        Cooldown -1
                        Distance 100
                        Duration 0.1
                        WaitUntilDone 0.1
                        OnDoneChangeAttributes "MasterMechanic_RailgunTankSummonReal"
                    }
                }
                MasterMechanic_RailgunTankSummonReal [$SIGSEGV]
                {
                    WeaponRestrictions MeleeOnly

                    CharacterAttributes
                    {
                        "move speed bonus" 0.001
                        "no_attack" 1
                        "no_jump" 1
                        "dmg from ranged reduced" 0.25
                        "dmg from melee increased" 0.25
                    }

                    ClientCommand
                    {
                        Name "eureka_teleport 1"
                        Delay 0.5
                        Repeats 1
                        Cooldown -1
                    }

                    FireInput
                    {
                        Target "MasterMechanic_RailgunTankPhase"
                        Action "Trigger"
                        Delay 2.5
                        Repeats 1
                        Cooldown -1
                    }
                }

                MasterMechanic_TankPowered [$SIGSEGV] // When he calls a tank in, he gains a vac bubble and becomes highly resistant to damage
                {
                    Item "The Wrangler"
                    WeaponRestrictions SecondaryOnly

                    CharacterAttributes
                    {
                        "dmg from ranged reduced" 0.1
                        "dmg from melee increased" 0.1
                    }

                    InterruptAction
                    {
                        Target "-6143 -5249 -712"
                        Delay 0
                        Repeats 99999
                        Distance 8
                        Duration 4
                        Cooldown 0.5
                    }

                    FireInput
                    {
                        Target "MasterMechanic_Shield"
                        Action "Enable"
                        Delay 0.5
                        Repeats 1
                        Cooldown -1
                    }
                }
                MasterMechanic_Stun [$SIGSEGV] // He becomes stunned for 5 seconds when a tank is killed; after this, the attack init is called
                {
                    CharacterAttributes
                    {
                        "dmg from ranged reduced" 1
                        "dmg from melee increased" 1
                    }
                    Addcond
                    {
                        Index 71
                        Duration 5
                    }

                    FireInput
                    {
                        Target "MasterMechanic_Shield"
                        Action "Disable"
                        Delay 0.5
                        Repeats 1
                        Cooldown -1
                    }

                    FireInput
                    {
                        Target "MasterMechanic_AttackInit"
                        Action Trigger
                        Delay 6
                        Repeats 1
                        Cooldown -1
                    }
                }

                // Phase 1 Attack Pool
                MasterMechanic_RescueRangerShotgun [$SIGSEGV]
                {
                    Item "The Rescue Ranger"
                    Attributes HoldFireUntilFullReload
                    WeaponRestrictions PrimaryOnly

                    ItemAttributes
                    {
                        ItemName "The Rescue Ranger"

                        "damage bonus" 1.5
                        "faster reload rate" 0.6
                        "projectile spread angle penalty" 5
                        "mult projectile count" 9
                    }

                    FireInput
                    {
                        Target "MasterMechanic_AttackInit"
                        Action "Trigger"
                        Delay 8
