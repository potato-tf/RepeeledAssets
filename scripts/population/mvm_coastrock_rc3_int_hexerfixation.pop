	Wave //Wave 06
	{
		StartWaveOutput
        {
            Target wave_start_relay
            Action Trigger
        }

        DoneOutput
        {
            Target wave_finished_relay
			Action RunScriptCode
			Param
			"
				self.AcceptInput(`Trigger`, ``, null, null)
				SendGlobalGameEvent(`teamplay_broadcast_audio`,
				{
					sound = `big_arms_boss_v2.wav`
					additional_flags = 0x4 // SND_STOP
					team = 255
        		})
			"
        }

