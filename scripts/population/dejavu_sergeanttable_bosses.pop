                "OnTrigger" "tf_gamerules,PlayVO,weapons/bottle_hit1.wav,12,-1"
                "OnTrigger"  "playerrunscriptcodeScreenShake(self.GetOrigin(), 5, 8, 1, 50000, 1, true)12-1"
                "OnTrigger"  "playerrunscriptcodeScreenShake(self.GetOrigin(), 5, 8, 1, 50000, 0, true)12.1-1"
                "OnTrigger" "tf_gamerules,PlayVO,weapons/bottle_hit1.wav,13,-1"
                "OnTrigger"  "playerrunscriptcodeScreenShake(self.GetOrigin(), 5, 8, 1, 50000, 1, true)13-1"
                "OnTrigger"  "playerrunscriptcodeScreenShake(self.GetOrigin(), 5, 8, 1, 50000, 0, true)13.1-1"
                "OnTrigger" "tf_gamerules,PlayVO,ambient/explosions/explode_1.wav,14,-1"
                "OnTrigger" "tf_gamerules,PlayVO,physics/glass/glass_sheet_break2.wav,14,-1"
                "OnTrigger" "the_funny_man_3,Disable,,14,-1"
                "OnTrigger" "soldiermdl*,Disable,,14,-1"
                "OnTrigger" "iceshield,Disable,,14,-1"
                "OnTrigger" "fake_boss_flavor*,Disable,,14,-1"
