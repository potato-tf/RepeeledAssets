    CustomWeapon
	{
        //// MAIN BOSSES ////

        //// MERCENARY MATTER ////
        "Merc_Matter_Volcano"
		{
			OriginalItemName "tf_weapon_rocketlauncher"
			"damage bonus" 1.25
			"blast radius increased" 2
			"projectile spread angle penalty" 50
			"attach particle effect" 1
			"projectile gravity" 500
			"projectile speed increased" 0.5
			"no self blast dmg" 1
			"Set DamageType Ignite" 1
			"ignores other projectiles" 1

			"projectile trail particle"spell_fireball_small_red
			"custom projectile model" models/weapons/w_models/w_drg_ball.mdl
			"custom kill icon" "spellbook_fireball"
		}

        //// SLAVE KNIGHT DAEL ////
        "Gael_Phase3_Explosion"
		{
			OriginalItemName "tf_weapon_rocketlauncher"
			"projectile trail particle" eyeboss_projectile
			"custom projectile model" models/props_mvm/mvm_human_skull.mdl
			"Projectile speed increased" 0.3
			"projectile spread angle penalty" 90
			"mod projectile heat seek power" 30
			"mod projectile heat aim error" 90
			"mod projectile heat aim time" 8
			"ragdolls become ash" 1
			"ignores other projectiles" 1
			"projectile gravity" 50
			"always crit" 1
		}

        //// MINI BOSSES ////

        //// EXPLOSIVE SURPRISE ////
		"ExplosiveSupriseVolcano1"
		{
			OriginalItemName "tf_weapon_grenadelauncher"
			"custom projectile model" "models/weapons/w_models/w_baseball.mdl"
			"mod stun waist high airborne" 1
			"projectile spread angle penalty" 30
			"fuse bonus" 3.5
			"projectile sound" "weapons\bat_baseball_hit1.wav"
		}
		"ExplosiveSupriseVolcano2"
		{
			OriginalItemName "tf_weapon_grenadelauncher"
			"custom projectile model" "models/weapons/w_models/w_baseball.mdl"
			"mod stun waist high airborne" 1
			"damage bonus" 0.6
			"projectile spread angle penalty" 60
			"fuse bonus" 3.5
			"projectile sound" "weapons\bat_baseball_hit1.wav"
		}

        //// TON 618 BLACK HOLE PYRO ////
		"BlackHoleFireballs"
		{
			OriginalItemName "tf_weapon_rocketlauncher"
			"projectile trail particle" spell_fireball_small_red
			"custom projectile model" models/weapons/w_models/w_drg_ball.mdl
			"custom kill icon" "spellbook_fireball"
			"mod projectile heat seek power" 35
			"mod projectile heat aim error" 999
			"mod projectile heat aim time" 3.5 
			"Projectile speed increased" 0.3
			"projectile spread angle penalty" 30
			"damage bonus" 0.65
			"ignores other projectiles" 1
		}
	}

