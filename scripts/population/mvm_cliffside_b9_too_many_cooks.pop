#base robot_giant.pop 
#base robot_standard.pop
// Too Many Cooks, Spoil The Soup.
// Chaos Mega Collab
// Made by Spectator, Pizzazz, TODO, sad man, Birch is Bad, Lobotomy, TheRealScroob, FANScout,
// A Bozo, ChristianGuyofAction, owo Inky, Reudina, Package O' Lies, B855, Chaos & Mystery, Lyney, Seelpit,
// Nuclear Waffle and The Fat.
// Put together by A Bozo.
// Formerly had a section made by StardustSpy but he was unavailable to fix it.
// Formerly had a section made by Blitz but he has a submission ban, so reject.
WaveSchedule
{

	StartingCurrency		1200
	RespawnWaveTime 		2
	CanBotsAttackWhileInSpawnRoom no
 	precachemodel "models/workshop/player/items/engineer/hwn2022_pony_express/hwn2022_pony_express.mdl"
	PrecacheModel "models/weapons/c_models/urinejar.mdl" //Need this to replace Jarate Demo's pipes
	PrecacheModel "models/workshop/weapons/c_models/c_browning/c_browning.mdl" // https://gamebanana.com/mods/360764
	NoRomevisionCosmetics 1  
	UpgradeStationKeepWeapons 1  
	TextPrintTime 0  
	PrecacheModel "models/weapons/c_models/c_wasp_launcher/c_wasp_launcher.mdl"   
	RemoveGrapplingHooks 4  

	PrecacheModel "models\player\soldier.mdl"  
	PrecacheModel "models\player\heavy.mdl"  
	PrecacheModel "models\player\pyro.mdl"  

	RobotLimit 60 //Lyney Does a little Trolling
	ExtraSpawnPoint
	{
		Name "spawnbot_telein"
		TeamNum 3
		StartDisabled 1
		X 1200
		Y 9000
		Z 700
	}
	
	DisallowUpgrade
	{
		Upgrade	"clip size upgrade atomic"
		ItemName "The Clipless Carrier"
	}
	DisallowUpgrade
	{
		Upgrade	"faster reload rate"
		ItemName "The Clipless Carrier"
	}
	ExtraSpawnPoint    
    {
        Name "spawnbot_miracle_matter" 
        TeamNum 3 
        X	"981"                     
        Y	"7499"                  
        Z	"551"   	
    }

