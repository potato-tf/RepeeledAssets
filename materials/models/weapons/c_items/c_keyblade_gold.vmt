"VertexLitGeneric"
{
	"$baseTexture" "models/weapons/c_items/c_keyblade_gold"
	"$bumpmap" "models/weapons/c_items/c_keyblade_normal"
	"$phong" "1"
	"$phongexponent" 50
	"$phongboost" "5"
	"$lightwarptexture" "models/lightwarps/weapon_lightwarp"	
	"$phongfresnelranges"	"[.25 .5 4]"
	"$bumpmapalphaphongmask" "1"

	// Begin GOLD look

	"$envmap" "cubemaps/cubemap_gold001"	
	
	// End GOLD look

	"$rimlight" "1"						
	"$rimlightexponent" "70"				
	"$rimlightboost" ".25"

	"$glowcolor" "1"

	// Cloaking
	"$cloakPassEnabled" "1"
	"$sheenPassEnabled" "1"

	"$sheenmap" "cubemaps/cubemap_sheen001"
	"$sheenmapmask" "effects/animatedsheen/animatedsheen0"
	"$sheenmaptint" 		"[ 1 1 1 ]"
	"$sheenmapmaskframe" 	"0"
	"$sheenindex" 		"0"

	"$yellow" "0"

	"Proxies"
	{
		"AnimatedWeaponSheen"
		{
			"animatedtexturevar" 		"$sheenmapmask"
			"animatedtextureframenumvar" 	"$sheenmapmaskframe"
			"animatedtextureframerate" 		"40"
		}
		"invis"
		{
		}
		"ModelGlowColor"
		{
			"resultVar" "$glowcolor"
		}
		"Equals"
		{
			"srcVar1"  "$glowcolor"
			"resultVar" "$selfillumtint"
		}
		"Equals"
		{
			"srcVar1"  "$glowcolor"
			"resultVar" "$color2"
		}
		"YellowLevel"
		{
			"resultVar" "$yellow"
		}
		"Multiply"
		{
			"srcVar1" "$color2"
			"srcVar2" "$yellow"
			"resultVar" "$color2"
		}
	}
}
